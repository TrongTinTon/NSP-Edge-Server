<odoo>
    <record id="view_nsp_branch_search" model="ir.ui.view">
        <field name="name">nsp.branch.search</field>
        <field name="model">nsp.branch</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="timezone"/>
                <field name="code" string="Technical Code"/>
                <filter string="Active" name="active" domain="[('status','=','active')]"/>
                <filter string="Inactive" name="inactive" domain="[('status','=','inactive')]"/>
            </search>
        </field>
    </record>
    <record id="view_nsp_branch_list" model="ir.ui.view">
        <field name="name">nsp.branch.list</field>
        <field name="model">nsp.branch</field>
        <field name="arch" type="xml">
            <list string="Branches">
                <field name="name" decoration-bf="1"/>
                <field name="timezone"/>
                <field name="status" widget="badge" decoration-success="status == 'active'" decoration-muted="status == 'inactive'"/>
                <field name="parking_area_count"/>
                <field name="code" string="Technical Code" optional="hide"/>
            </list>
        </field>
    </record>
    <record id="view_nsp_branch_form" model="ir.ui.view">
        <field name="name">nsp.branch.form</field>
        <field name="model">nsp.branch</field>
        <field name="arch" type="xml">
            <form string="Branch">
                <sheet>
                    <div class="oe_title"><label for="name"/><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="status" widget="radio"/>
                            <field name="timezone"/>
                        </group>
                        <group><field name="parking_area_count" readonly="1"/></group>
                    </group>
                    <notebook>
                        <page string="Parking Areas">
                            <field name="parking_area_ids" readonly="1">
                                <list string="Parking Areas">
                                    <field name="name"/>
                                    <field name="controller_ids" widget="many2many_tags"/>
                                    <field name="state" widget="badge"/>
                                    <field name="code" string="Technical Code" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes"><field name="note" placeholder="Internal note..."/></page>
                        <page string="Technical" groups="nsp_core.group_nsp_it_parking"><group><field name="code" readonly="1" widget="CopyClipboardChar"/></group></page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_nsp_branch" model="ir.actions.act_window">
        <field name="name">Branches</field><field name="res_model">nsp.branch</field><field name="view_mode">list,form</field><field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>
