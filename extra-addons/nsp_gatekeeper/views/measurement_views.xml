<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nsp_measurement_session_search" model="ir.ui.view">
        <field name="name">nsp.measurement.session.search</field>
        <field name="model">nsp.measurement.session</field>
        <field name="arch" type="xml">
            <search>
                <field name="measurement_code"/>
                <field name="controller_id"/>
                <filter string="Draft" name="draft" domain="[('status','=','draft')]"/>
                <filter string="Ready" name="ready" domain="[('status','=','ready')]"/>
                <filter string="Running" name="running" domain="[('status','=','running')]"/>
                <filter string="Completed" name="completed" domain="[('status','=','completed')]"/>
                <filter string="Failed" name="failed" domain="[('status','=','failed')]"/>
                <group>
                    <filter string="Controller" name="group_controller" context="{'group_by':'controller_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by':'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_nsp_measurement_session_list" model="ir.ui.view">
        <field name="name">nsp.measurement.session.list</field>
        <field name="model">nsp.measurement.session</field>
        <field name="arch" type="xml">
            <list string="Measurement Sessions"
                  decoration-info="status == 'running'"
                  decoration-success="status == 'completed'"
                  decoration-danger="status == 'failed'">
                <field name="measurement_code"/>
                <field name="controller_id"/>
                <field name="planned_start_at"/>
                <field name="planned_end_at"/>
                <field name="status" widget="badge"/>
                <field name="event_count"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_measurement_session_form" model="ir.ui.view">
        <field name="name">nsp.measurement.session.form</field>
        <field name="model">nsp.measurement.session</field>
        <field name="arch" type="xml">
            <form string="Measurement Session">
                <header>
                    <button name="action_ready" type="object" string="Release to Controller"
                            class="oe_highlight" invisible="status != 'draft'"/>
                    <button name="action_complete" type="object" string="Complete"
                            class="oe_highlight" invisible="status != 'running'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="status in ('completed','failed','cancelled')"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,ready,running,completed,failed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_live" type="object" class="oe_stat_button" icon="fa-line-chart"
                                invisible="status == 'draft'">
                            <span class="o_stat_text">Live Measurement</span>
                        </button>
                        <button name="action_view_events" type="object" class="oe_stat_button" icon="fa-list">
                            <field name="event_count" widget="statinfo" string="Events"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="measurement_code"/>
                        <h1><field name="measurement_code" placeholder="MSR-BD-GATE01-001"/></h1>
                    </div>
                    <group>
                        <group string="Measurement Plan">
                            <field name="controller_id"/>
                            <field name="planned_start_at"/>
                            <field name="planned_end_at"/>
                        </group>
                        <group string="Runtime">
                            <field name="started_at" readonly="1"/>
                            <field name="ended_at" readonly="1"/>
                            <field name="event_count" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" placeholder="Measurement purpose or notes"/>
                    </group>
                    <notebook>
                        <page string="Devices and Antennas">
                            <field name="antenna_ids" domain="[('device_id.controller_id','=',controller_id)]">
                                <list create="0" delete="1">
                                    <field name="device_serial" string="Reader Serial"/>
                                    <field name="device_id" string="Reader"/>
                                    <field name="antenna_no" string="Antenna No"/>
                                </list>
                            </field>
                        </page>
                        <page string="Recent Events">
                            <field name="event_ids" readonly="1">
                                <list create="0" delete="0" default_order="read_at desc" limit="100">
                                    <field name="read_at"/>
                                    <field name="serial_number"/>
                                    <field name="antenna_no"/>
                                    <field name="tid"/>
                                    <field name="rssi_dbm"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_nsp_measurement_event_search" model="ir.ui.view">
        <field name="name">nsp.measurement.event.search</field>
        <field name="model">nsp.measurement.event</field>
        <field name="arch" type="xml">
            <search>
                <field name="event_uid"/>
                <field name="session_id"/>
                <field name="serial_number"/>
                <field name="antenna_no"/>
                <field name="tid"/>
                <filter string="Session" name="group_session" context="{'group_by':'session_id'}"/>
                <filter string="Reader" name="group_reader" context="{'group_by':'serial_number'}"/>
                <filter string="Antenna" name="group_antenna" context="{'group_by':'antenna_no'}"/>
            </search>
        </field>
    </record>

    <record id="view_nsp_measurement_event_list" model="ir.ui.view">
        <field name="name">nsp.measurement.event.list</field>
        <field name="model">nsp.measurement.event</field>
        <field name="arch" type="xml">
            <list string="Measurement Events" create="0" edit="0" delete="0">
                <field name="read_at"/>
                <field name="event_uid" optional="hide"/>
                <field name="session_id"/>
                <field name="serial_number"/>
                <field name="antenna_no"/>
                <field name="tid"/>
                <field name="rssi_dbm"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_measurement_event_form" model="ir.ui.view">
        <field name="name">nsp.measurement.event.form</field>
        <field name="model">nsp.measurement.event</field>
        <field name="arch" type="xml">
            <form string="Measurement Event" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <field name="event_uid"/>
                        <field name="session_id"/>
                        <field name="serial_number"/>
                        <field name="antenna_no"/>
                        <field name="tid"/>
                        <field name="read_at"/>
                        <field name="rssi_dbm"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nsp_measurement_session" model="ir.actions.act_window">
        <field name="name">Measurement Sessions</field>
        <field name="res_model">nsp.measurement.session</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_nsp_measurement_session_search"/>
    </record>

    <record id="action_nsp_measurement_event" model="ir.actions.act_window">
        <field name="name">Measurement Events</field>
        <field name="res_model">nsp.measurement.event</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_nsp_measurement_event_search"/>
    </record>
</odoo>
