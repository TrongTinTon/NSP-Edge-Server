<odoo>
    <record id="view_nsp_parking_dashboard_metric_search" model="ir.ui.view">
        <field name="name">view.nsp.parking.dashboard.metric.search</field>
        <field name="model">nsp.parking.dashboard.metric</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="category"/>
                <field name="severity"/>
                <filter string="Warnings" name="warnings" domain="[('severity','in',['warning','critical'])]"/>
                <filter string="Traffic" name="traffic" domain="[('category','=','traffic')]"/>
                <filter string="Alerts" name="alerts" domain="[('category','=','alert')]"/>
                <filter string="Devices" name="devices" domain="[('category','=','device')]"/>
                <filter string="Config" name="config" domain="[('category','=','config')]"/>
                <group>
                    <filter string="Category" name="group_category" context="{'group_by':'category'}"/>
                    <filter string="Severity" name="group_severity" context="{'group_by':'severity'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="view_nsp_parking_dashboard_metric_list" model="ir.ui.view">
        <field name="name">view.nsp.parking.dashboard.metric.list</field>
        <field name="model">nsp.parking.dashboard.metric</field>
        <field name="arch" type="xml">
            <list string="NSP IT Dashboard" create="0" edit="0" delete="0" default_order="sequence">
                <field name="category" widget="badge"/>
                <field name="severity" widget="badge" decoration-success="severity == 'normal'" decoration-info="severity == 'info'" decoration-warning="severity == 'warning'" decoration-danger="severity == 'critical'"/>
                <field name="name"/>
                <field name="value_int" sum="Total"/>
                <field name="help_text" optional="show"/>
                <field name="generated_at" optional="hide"/>
            </list>
        </field>
    </record>
    <record id="view_nsp_parking_dashboard_metric_form" model="ir.ui.view">
        <field name="name">view.nsp.parking.dashboard.metric.form</field>
        <field name="model">nsp.parking.dashboard.metric</field>
        <field name="arch" type="xml">
            <form string="NSP IT Dashboard Metric" create="0" edit="0" delete="0">
                <header><button name="action_open_records" type="object" string="Open Related Records" class="btn-primary"/></header>
                <sheet>
                    <div class="oe_title"><label for="name"/><h1><field name="name" readonly="1"/></h1></div>
                    <group><group><field name="category" readonly="1" widget="badge"/><field name="severity" readonly="1" widget="badge"/><field name="value_int" readonly="1"/></group><group><field name="code" readonly="1"/><field name="generated_at" readonly="1"/></group></group>
                    <group string="Meaning"><field name="help_text" readonly="1" nolabel="1"/></group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_nsp_parking_it_dashboard" model="ir.actions.act_window">
        <field name="name">IT Dashboard</field>
        <field name="res_model">nsp.parking.dashboard.metric</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_nsp_parking_dashboard_metric_search"/>
        <field name="context">{'search_default_warnings': 1}</field>
    </record>
</odoo>
