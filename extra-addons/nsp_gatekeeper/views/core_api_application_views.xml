<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_core_api_application_form_nsp_controller" model="ir.ui.view">
        <field name="name">core.api.application.form.nsp.controller</field>
        <field name="model">core.api.application</field>
        <field name="inherit_id" ref="t4_coreapi.view_core_api_application_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_nsp_controllers" type="object" class="oe_stat_button" icon="fa-sitemap" invisible="not id">
                    <field name="nsp_controller_count" widget="statinfo" string="NSP Nodes"/>
                </button>
            </xpath>
            <xpath expr="//page[@name='security']" position="after">
                <page string="NSP Nodes" name="nsp_nodes">
                    <field name="nsp_controller_ids" context="{'default_core_api_application_id': id}">
                        <list create="0" delete="0">
                            <field name="controller_id"/>
                            <field name="controller_name"/>
                            <field name="node_type" widget="badge"/>
                            <field name="parent_id"/>
                            <field name="status" widget="badge"/>
                            <field name="timestamp"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
