<odoo>
    <record id="view_nsp_parking_transaction_search" model="ir.ui.view">
        <field name="name">view.nsp.parking.transaction.search</field>
        <field name="model">nsp.parking.transaction</field>
        <field name="arch" type="xml">
            <search>
                <field name="transaction_uid"/>
                <field name="controller_id"/>
                <field name="parking_area_id"/>
                <field name="lane_id"/>
                <field name="device_id"/>
                <field name="antenna_id"/>
                <field name="vehicle_id"/>
                <field name="license_plate"/>
                <field name="vehicle_tid"/>
                <field name="user_id"/>
                <field name="user_tid"/>
                <field name="borrow_request_id"/>
                <field name="direction"/>
                <field name="status"/>
                <field name="error_code"/>
                <filter string="Entry" name="entry" domain="[('direction','=','entry')]"/>
                <filter string="Exit" name="exit" domain="[('direction','=','exit')]"/>
                <filter string="Allowed" name="allowed" domain="[('status','=','allowed')]"/>
                <filter string="Denied" name="denied" domain="[('status','=','denied')]"/>
                <filter string="Missing Vehicle Card" name="missing_vehicle_tid" domain="[('error_code','=','missing_vehicle_tid')]"/>
                <filter string="Missing User Card" name="missing_user_tid" domain="[('error_code','=','missing_user_tid')]"/>
                <filter string="Authentication Errors" name="auth_errors"
                        domain="[('error_code','in',['vehicle_card_unknown','vehicle_not_found','user_card_unknown','user_not_assigned','borrow_not_allowed'])]"/>
                <separator/>
                <filter string="Controller" name="group_controller" context="{'group_by':'controller_id'}"/>
                <filter string="Lane" name="group_lane" context="{'group_by':'lane_id'}"/>
                <filter string="Direction" name="group_direction" context="{'group_by':'direction'}"/>
                <filter string="Decision" name="group_status" context="{'group_by':'status'}"/>
                <filter string="Decision Reason" name="group_error_code" context="{'group_by':'error_code'}"/>
                <filter string="Vehicle" name="group_vehicle" context="{'group_by':'vehicle_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_nsp_parking_transaction_list" model="ir.ui.view">
        <field name="name">view.nsp.parking.transaction.list</field>
        <field name="model">nsp.parking.transaction</field>
        <field name="arch" type="xml">
            <list string="Parking Logs" create="0" edit="0" delete="0">
                <field name="time_entered" string="Event Time"/>
                <field name="parking_area_display" string="Parking Area"/>
                <field name="lane_display" string="Lane"/>
                <field name="vehicle_display" string="Vehicle"/>
                <field name="user_id" optional="show"/>
                <field name="direction" widget="badge"
                       decoration-success="direction == 'entry'"
                       decoration-info="direction == 'exit'"/>
                <field name="status" string="Decision" widget="badge"
                       decoration-success="status == 'allowed'"
                       decoration-danger="status == 'denied'"/>
                <field name="error_code" string="Reason" widget="badge" optional="show"/>
                <field name="controller_id" optional="hide"/>
                <field name="device_id" optional="hide"/>
                <field name="antenna_no" optional="hide"/>
                <field name="vehicle_tid" optional="hide"/>
                <field name="user_tid" optional="hide"/>
                <field name="transaction_uid" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_parking_transaction_form" model="ir.ui.view">
        <field name="name">view.nsp.parking.transaction.form</field>
        <field name="model">nsp.parking.transaction</field>
        <field name="arch" type="xml">
            <form string="Parking Log" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group string="Event">
                            <field name="transaction_uid"/>
                            <field name="time_entered"/>
                            <field name="direction" widget="badge"/>
                            <field name="status" string="Decision" widget="badge"/>
                            <field name="error_code" string="Decision Reason"/>
                            <field name="error_message" string="Decision Message"/>
                        </group>
                        <group string="Location and Device">
                            <field name="controller_id"/>
                            <field name="parking_area_id"/>
                            <field name="lane_id"/>
                            <field name="device_id"/>
                            <field name="antenna_id"/>
                            <field name="serial_number"/>
                            <field name="antenna_no"/>
                        </group>
                    </group>
                    <group>
                        <group string="Vehicle">
                            <field name="vehicle_id"/>
                            <field name="license_plate"/>
                            <field name="vehicle_tid"/>
                        </group>
                        <group string="User and Borrow">
                            <field name="user_id"/>
                            <field name="user_tid"/>
                            <field name="borrow_request_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nsp_parking_transaction" model="ir.actions.act_window">
        <field name="name">Parking Logs</field>
        <field name="res_model">nsp.parking.transaction</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
