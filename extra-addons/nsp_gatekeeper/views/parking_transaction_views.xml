<odoo>
    <record id="view_nsp_parking_transaction_search" model="ir.ui.view">
        <field name="name">view.nsp.parking.transaction.search</field>
        <field name="model">nsp.parking.transaction</field>
        <field name="arch" type="xml">
            <search>
                <field name="controller_id"/>
                <field name="parking_area_id"/>
                <field name="parking_area_code"/>
                <field name="lane_id"/>
                <field name="lane_code"/>
                <field name="vehicle_code"/>
                <field name="license_plate"/>
                <field name="vehicle_tid"/>
                <field name="user_id"/>
                <field name="user_code"/>
                <field name="user_tid"/>
                <field name="borrow_request_id"/>
                <field name="borrower_id"/>
                <field name="direction"/>
                <field name="status"/>
                <field name="error_code"/>
                <field name="error_category"/>
                <field name="error_severity"/>
                <filter string="Entry" name="entry" domain="[('direction','=','entry')]"/>
                <filter string="Exit" name="exit" domain="[('direction','=','exit')]"/>
                <filter string="Allowed" name="allowed" domain="[('status','=','allowed')]"/>
                <filter string="Denied" name="denied" domain="[('status','=','denied')]"/>
                <filter string="Requires Attention" name="alert_required" domain="[('alert_required','=',True)]"/>
                <filter string="Missing Vehicle Card" name="missing_vehicle_tid" domain="[('error_code','=','missing_vehicle_tid')]"/>
                <filter string="Missing Employee Card" name="missing_user_tid" domain="[('error_code','=','missing_user_tid')]"/>
                <filter string="Authentication Errors" name="auth_errors" domain="[('error_category','in',['auth','borrow'])]"/>
                <separator/>
                    <filter string="Controller" name="group_controller" context="{'group_by':'controller_id'}"/>
                    <filter string="Parking Area" name="group_parking_area" context="{'group_by':'parking_area_id'}"/>
                    <filter string="Lane" name="group_lane" context="{'group_by':'lane_id'}"/>
                    <filter string="Direction" name="group_direction" context="{'group_by':'direction'}"/>
                    <filter string="Status" name="group_status" context="{'group_by':'status'}"/>
                    <filter string="Alert Code" name="group_error_code" context="{'group_by':'error_code'}"/>
                    <filter string="Alert Category" name="group_error_category" context="{'group_by':'error_category'}"/>
                    <filter string="Vehicle" name="group_vehicle" context="{'group_by':'vehicle_id'}"/>
                </search>
        </field>
    </record>

    <record id="view_nsp_parking_transaction_list" model="ir.ui.view">
        <field name="name">view.nsp.parking.transaction.list</field>
        <field name="model">nsp.parking.transaction</field>
        <field name="arch" type="xml">
            <list string="Vehicle In/Out Logs" create="0">
                <field name="parking_area_display" string="Parking Area"/>
                <field name="lane_display" string="Lane"/>
                <field name="vehicle_display" string="Vehicle"/>
                <field name="direction" widget="badge" decoration-success="direction == 'entry'" decoration-info="direction == 'exit'"/>
                <field name="status" widget="badge" decoration-success="status == 'allowed'" decoration-danger="status == 'denied'"/>
                <field name="error_code" widget="badge" decoration-danger="error_severity == 'critical'" decoration-warning="error_severity == 'warning'" optional="show"/>
                <field name="time_entered" string="Event Time"/>
                <field name="vehicle_code" optional="hide"/>
                <field name="user_code" optional="hide"/>
                <field name="license_plate" optional="hide"/>
                <field name="vehicle_tid" optional="hide"/>
                <field name="user_tid" optional="hide"/>
                <field name="controller_id" optional="hide"/>
                <field name="parking_area_id" optional="hide"/>
                <field name="lane_id" optional="hide"/>
                <field name="error_category" optional="hide"/>
                <field name="error_severity" optional="hide"/>
                <field name="alert_required" optional="hide"/>
                <field name="error_message" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_parking_transaction_form" model="ir.ui.view">
        <field name="name">view.nsp.parking.transaction.form</field>
        <field name="model">nsp.parking.transaction</field>
        <field name="arch" type="xml">
            <form string="Vehicle In/Out Log" create="0">
                <sheet>
                    <group>
                        <group string="Main Information">
                            <field name="parking_area_display" string="Parking Area" readonly="1"/>
                            <field name="lane_display" string="Lane" readonly="1"/>
                            <field name="vehicle_display" string="Vehicle" readonly="1"/>
                            <field name="direction" widget="badge"/>
                            <field name="status" widget="badge"/>
                            <field name="time_entered" string="Event Time"/>
                        </group>
                        <group string="Vehicle / Card">
                            <field name="vehicle_id"/>
                            <field name="vehicle_code"/>
                            <field name="license_plate"/>
                            <field name="vehicle_tid"/>
                            <field name="vehicle_card_id"/>
                            <field name="user_id"/>
                            <field name="user_code"/>
                            <field name="user_tid"/>
                <field name="borrow_request_id"/>
                <field name="borrower_id"/>
                            <field name="user_card_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Node / Route">
                            <field name="controller_id"/>
                            <field name="parking_area_id"/>
                            <field name="parking_area_code"/>
                            <field name="lane_id"/>
                            <field name="lane_code"/>
                            <field name="transaction_uid"/>
                                                </group>
                        <group string="Alert / Error">
                            <field name="alert_required"/>
                            <field name="error_code"/>
                            <field name="error_codes"/>
                            <field name="error_category"/>
                            <field name="error_severity"/>
                            <field name="error_message"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nsp_parking_transaction" model="ir.actions.act_window">
        <field name="name">Vehicle In/Out Logs</field>
        <field name="res_model">nsp.parking.transaction</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
