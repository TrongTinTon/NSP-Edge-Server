<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nsp_parking_area_search" model="ir.ui.view">
        <field name="name">nsp.parking.operation.search</field>
        <field name="model">nsp.parking.area</field>
        <field name="arch" type="xml">
            <search string="Parking Operation Configurations">
                <field name="name"/>
                <field name="code"/>
                <field name="branch_id"/>
                <field name="controller_ids"/>
                <filter string="Operational" name="operational" domain="[('state','=','operational')]"/>
                <filter string="Configuring" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Maintenance" name="maintenance" domain="[('state','=','maintenance')]"/>
                <filter string="Blocked" name="blocked" domain="[('state','=','blocked')]"/>
                <separator/>
                <group>
                    <filter string="Branch" name="group_branch" context="{'group_by':'branch_id'}"/>
                    <filter string="State" name="group_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_nsp_parking_area_list" model="ir.ui.view">
        <field name="name">nsp.parking.operation.list</field>
        <field name="model">nsp.parking.area</field>
        <field name="arch" type="xml">
            <list string="Parking Operation Configurations">
                <field name="state" widget="badge"
                       decoration-success="state == 'operational'"
                       decoration-warning="state == 'draft' or state == 'maintenance'"
                       decoration-danger="state == 'blocked'"/>
                <field name="name"/>
                <field name="code" string="Technical Code" optional="hide"/>
                <field name="branch_id"/>
                <field name="edge_server_count" string="Edge Servers"/>
                <field name="controller_count" string="Controllers"/>
                <field name="reader_count" string="Readers"/>
                <field name="lane_count" string="Lanes"/>
                <field name="antenna_count" string="Antennas"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_parking_area_form" model="ir.ui.view">
        <field name="name">nsp.parking.operation.form</field>
        <field name="model">nsp.parking.area</field>
        <field name="arch" type="xml">
            <form string="Parking Operation Configuration">
                <header>
                    <button name="action_set_operational" type="object" string="Set Operational"
                            class="oe_highlight" invisible="state == 'operational'"/>
                    <button name="action_set_maintenance" type="object" string="Set Maintenance"
                            invisible="state == 'maintenance'"/>
                    <button name="action_set_blocked" type="object" string="Block"
                            invisible="state == 'blocked'"/>
                    <button name="action_reset_to_draft" type="object" string="Back to Configuration"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,operational,maintenance,blocked"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_live_monitor" type="object" class="oe_stat_button" icon="fa-desktop"
                                groups="nsp_core.group_nsp_operator,nsp_core.group_nsp_it_parking,base.group_system">
                            <span class="o_stat_text">Live Monitor</span>
                        </button>
                        <button name="action_open_edge_servers" type="object" class="oe_stat_button" icon="fa-server">
                            <field name="edge_server_count" widget="statinfo" string="Edge Servers"/>
                        </button>
                        <button name="action_open_controllers" type="object" class="oe_stat_button" icon="fa-sitemap">
                            <field name="controller_count" widget="statinfo" string="Controllers"/>
                        </button>
                        <button name="action_open_readers" type="object" class="oe_stat_button" icon="fa-rss">
                            <field name="reader_count" widget="statinfo" string="Readers"/>
                        </button>
                        <button name="action_open_antennas" type="object" class="oe_stat_button" icon="fa-signal">
                            <field name="antenna_count" widget="statinfo" string="Antennas"/>
                        </button>
                        <button name="action_open_device_whitelist" type="object" class="oe_stat_button" icon="fa-shield">
                            <field name="whitelist_count" widget="statinfo" string="Whitelist"/>
                        </button>
                        <button name="action_open_lanes" type="object" class="oe_stat_button" icon="fa-road">
                            <field name="lane_count" widget="statinfo" string="Lanes"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Parking Area A"/></h1>
                    </div>

                    <div class="alert alert-info" role="alert">
                        Configure the server-owned parking topology here. Each lane selects one Controller and one lane direction. For Two-way lanes, map Reader antenna ports to Outside or Inside zones; One-way lanes do not require zones. Controllers receive only Reader parameters and per-antenna RF settings; branch, parking area and lane business rules remain on the server.
                    </div>

                    <group>
                        <group string="Parking Operation">
                            <field name="branch_id" options="{'no_create': False, 'no_open': False}"/>
                            <field name="state" readonly="1"/>
                            <field name="motorbike_capacity" string="Motorbike Capacity"/>
                            <field name="code" string="Technical Code" readonly="1" widget="CopyClipboardChar" groups="nsp_core.group_nsp_it_parking"/>
                        </group>
                        <group string="Derived Infrastructure">
                            <field name="edge_server_ids" widget="many2many_tags" readonly="1"/>
                            <field name="controller_ids" widget="many2many_tags" readonly="1"/>
                            <field name="reader_ids" widget="many2many_tags" readonly="1"/>
                            <field name="antenna_ids" widget="many2many_tags" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="1. Parking Lanes">
                            <div class="alert alert-secondary" role="alert">
                                Assign one Controller and one operating direction to each lane. Vehicle RFID is always required. Check-in never requires User RFID. Check-out always requires exactly one User RFID; Edge pairs the nearest unused User detection by timestamp within the grouping window. For a Two-way lane, map antennas to Outside and Inside zones to resolve movement.
                            </div>
                            <field name="lane_ids" context="{'default_parking_area_id': id}">
                                <list editable="bottom">
                                    <field name="lane_no" string="Lane No"/>
                                    <field name="name" string="Lane Name"/>
                                    <field name="code" string="Technical Code" optional="hide" readonly="1"/>
                                    <field name="controller_id" options="{'no_create': False, 'no_open': False}"/>
                                    <field name="direction"/>
                                    <field name="transition_window_seconds" optional="hide"/>
                                    <field name="grouping_window_seconds" optional="hide"/>
                                    <field name="repeat_suppression_seconds" optional="hide"/>
                                    <field name="active" widget="boolean_toggle"/>
                                    <field name="antenna_count" string="Mapped Antennas" readonly="1"/>
                                </list>
                            </field>
                        </page>

                        <page string="2. Antenna Mapping">
                            <div class="alert alert-secondary" role="alert">
                                For a Two-way lane, configure each antenna as Outside or Inside. Outside → Inside means Entry/Check-in; Inside → Outside means Exit/Check-out. One-way lanes do not require antenna zones.
                            </div>
                            <button name="action_open_antenna_mappings" type="object"
                                    string="Configure Antenna Mappings" class="oe_highlight" icon="fa-exchange"/>
                            <field name="lane_antenna_mapping_ids" readonly="1">
                                <list create="0" delete="0">
                                    <field name="lane_id"/>
                                    <field name="zone"/>
                                    <field name="controller_id"/>
                                    <field name="device_id" string="Reader"/>
                                    <field name="serial_number" string="Reader Serial" optional="hide"/>
                                    <field name="antenna_no" string="Antenna No"/>
                                    <field name="minimum_rssi_dbm" string="Minimum RSSI dBm"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nsp_parking_area" model="ir.actions.act_window">
        <field name="name">Parking Operation Configurations</field>
        <field name="res_model">nsp.parking.area</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_nsp_parking_area_search"/>
    </record>

    <record id="view_nsp_parking_lane_list" model="ir.ui.view">
        <field name="name">nsp.parking.lane.list</field>
        <field name="model">nsp.parking.lane</field>
        <field name="arch" type="xml">
            <list string="Parking Lanes">
                <field name="parking_area_id"/>
                <field name="lane_no" string="Lane No"/>
                <field name="name" string="Lane Name" decoration-bf="1"/>
                <field name="code" string="Technical Code" optional="hide" readonly="1"/>
                <field name="controller_id"/>
                <field name="direction"/>
                <field name="antenna_count" string="Antennas"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_parking_lane_form" model="ir.ui.view">
        <field name="name">nsp.parking.lane.form</field>
        <field name="model">nsp.parking.lane</field>
        <field name="arch" type="xml">
            <form string="Parking Lane">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Entry Lane 01"/></h1>
                    </div>
                    <group>
                        <group string="Lane Declaration">
                            <field name="parking_area_id" options="{'no_create': False, 'no_open': False}"/>
                            <field name="controller_id" options="{'no_create': False, 'no_open': False}"/>
                            <field name="lane_no" string="Lane No"/>
                            <field name="active"/>
                        </group>
                        <group string="Event Processing">
                            <field name="direction"/>
                            <field name="transition_window_seconds" invisible="direction != 'both'"/>
                            <field name="grouping_window_seconds"/>
                            <field name="repeat_suppression_seconds"/>
                            <field name="antenna_count" readonly="1"/>
                            <field name="code" string="Technical Code" readonly="1" widget="CopyClipboardChar" groups="nsp_core.group_nsp_it_parking"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Antenna Mapping">
                            <div class="alert alert-info" role="alert">
                                Select only antennas belonging to the Lane Controller. Two-way lanes require Outside/Inside zones. One-way lanes leave Zone empty. Reader Power and Minimum RSSI remain Reader/Antenna technical settings.
                            </div>
                            <field name="antenna_mapping_ids" context="{'default_lane_id': id}">
                                <list editable="bottom">
                                    <field name="lane_controller_id" column_invisible="1"/>
                                    <field name="zone"/>
                                    <field name="antenna_ref_id" string="Antenna"
                                           domain="[('device_id.controller_id','=',parent.controller_id)]"/>
                                    <field name="device_id" string="Reader" readonly="1"/>
                                    <field name="serial_number" string="Reader Serial" readonly="1" optional="hide"/>
                                    <field name="antenna_no" string="Antenna No" readonly="1"/>
                                    <field name="minimum_rssi_dbm" string="Minimum RSSI dBm" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nsp_parking_lane" model="ir.actions.act_window">
        <field name="name">Parking Lanes</field>
        <field name="res_model">nsp.parking.lane</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_nsp_parking_lane_antenna_mapping_list" model="ir.ui.view">
        <field name="name">nsp.parking.lane.antenna.mapping.list</field>
        <field name="model">nsp.parking.lane.antenna.mapping</field>
        <field name="arch" type="xml">
            <list string="Parking Lane Antenna Mapping" editable="bottom">
                <field name="lane_controller_id" column_invisible="1"/>
                <field name="parking_area_id" readonly="1"/>
                <field name="lane_id"/>
                <field name="zone"/>
                <field name="antenna_ref_id" string="Antenna"
                       domain="[('device_id.controller_id','=',lane_controller_id)]"/>
                <field name="controller_id" readonly="1"/>
                <field name="device_id" string="Reader" readonly="1"/>
                <field name="serial_number" string="Reader Serial" readonly="1" optional="hide"/>
                <field name="antenna_no" string="Antenna No" readonly="1"/>
                <field name="minimum_rssi_dbm" string="Minimum RSSI dBm" readonly="1"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_parking_lane_antenna_mapping_form" model="ir.ui.view">
        <field name="name">nsp.parking.lane.antenna.mapping.form</field>
        <field name="model">nsp.parking.lane.antenna.mapping</field>
        <field name="arch" type="xml">
            <form string="Parking Lane Antenna Mapping">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="rule_name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Lane">
                            <field name="lane_id"/>
                            <field name="parking_area_id" readonly="1"/>
                            <field name="lane_controller_id" readonly="1"/>
                            <field name="zone"/>
                        </group>
                        <group string="Antenna">
                            <field name="antenna_ref_id"
                                   domain="[('device_id.controller_id','=',lane_controller_id)]"/>
                            <field name="controller_id" readonly="1"/>
                            <field name="device_id" string="Reader" readonly="1"/>
                            <field name="serial_number" string="Reader Serial" readonly="1"/>
                            <field name="antenna_no" string="Antenna No" readonly="1"/>
                                        <field name="minimum_rssi_dbm" string="Minimum RSSI dBm" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nsp_parking_lane_antenna_mapping" model="ir.actions.act_window">
        <field name="name">Parking Lane Antenna Mapping</field>
        <field name="res_model">nsp.parking.lane.antenna.mapping</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
