<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nsp_controller_pairing_request_search" model="ir.ui.view">
        <field name="name">nsp.controller.pairing.request.search</field>
        <field name="model">nsp.controller.pairing.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="pairing_request_uid"/>
                <field name="edge_server_id"/>
                <field name="machine_id"/>
                <field name="machine_name"/>
                <field name="controller_id"/>
                <filter string="Pending" name="pending" domain="[('pairing_status','=','pending')]"/>
                <filter string="Approved" name="approved" domain="[('pairing_status','=','approved')]"/>
                <filter string="Delivered" name="delivered" domain="[('pairing_status','=','delivered')]"/>
                <filter string="Closed" name="closed" domain="[('pairing_status','in',['rejected','expired','cancelled'])]"/>
                <group>
                    <filter string="Edge Server" name="group_edge_server" context="{'group_by':'edge_server_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by':'pairing_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_nsp_controller_pairing_request_list" model="ir.ui.view">
        <field name="name">nsp.controller.pairing.request.list</field>
        <field name="model">nsp.controller.pairing.request</field>
        <field name="arch" type="xml">
            <list string="Controller Pairing Requests" create="0" delete="0" default_order="requested_at desc">
                <field name="requested_at"/>
                <field name="pairing_request_uid" optional="hide"/>
                <field name="edge_server_id"/>
                <field name="machine_id"/>
                <field name="machine_name" optional="show"/>
                <field name="software_version" optional="show"/>
                <field name="controller_id"/>
                <field name="expires_at" optional="show"/>
                <field name="pairing_status" widget="badge" decoration-warning="pairing_status == 'pending'" decoration-info="pairing_status == 'approved'" decoration-success="pairing_status == 'delivered'" decoration-danger="pairing_status in ('rejected','expired','cancelled')"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_controller_pairing_request_form" model="ir.ui.view">
        <field name="name">nsp.controller.pairing.request.form</field>
        <field name="model">nsp.controller.pairing.request</field>
        <field name="arch" type="xml">
            <form string="Controller Pairing Request" create="0" delete="0">
                <header>
                    <button name="action_approve" type="object" string="Approve" class="oe_highlight" invisible="pairing_status != 'pending'" groups="nsp_core.group_nsp_it_parking,t4_coreapi.group_core_api_manager"/>
                    <button name="action_reject" type="object" string="Reject" invisible="pairing_status != 'pending'" groups="nsp_core.group_nsp_it_parking,t4_coreapi.group_core_api_manager"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="pairing_status not in ('pending','approved')" groups="nsp_core.group_nsp_it_parking,t4_coreapi.group_core_api_manager"/>
                    <button name="action_open_controller" type="object" string="Open Controller" invisible="not controller_id"/>
                    <field name="pairing_status" widget="statusbar" statusbar_visible="pending,approved,delivered,rejected,expired,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="machine_id"/>
                        <h1><field name="machine_id" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Request">
                            <field name="pairing_request_uid" readonly="1"/>
                            <field name="edge_server_id" readonly="1"/>
                            <field name="machine_name" readonly="1"/>
                            <field name="software_version" readonly="1"/>
                            <field name="requested_at" readonly="1"/>
                            <field name="expires_at" readonly="1"/>
                        </group>
                        <group string="Approval">
                            <field name="controller_id" domain="[('node_type','=','controller'),('parent_id','=',edge_server_id)]" readonly="pairing_status != 'pending'"/>
                            <field name="approved_at" readonly="1"/>
                            <field name="delivered_at" readonly="1"/>
                            <field name="rejection_reason_code" readonly="pairing_status != 'pending'"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_nsp_controller_pairing_requests" model="ir.actions.act_window">
        <field name="name">Controller Pairing Requests</field>
        <field name="res_model">nsp.controller.pairing.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_nsp_controller_pairing_request_search"/>
        <field name="context">{'search_default_pending': 1}</field>
    </record>
</odoo>
