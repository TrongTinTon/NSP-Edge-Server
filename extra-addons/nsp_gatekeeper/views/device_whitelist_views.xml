<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="nsp_device_whitelist_search_view" model="ir.ui.view">
        <field name="name">nsp.device.whitelist.search</field>
        <field name="model">nsp.device.whitelist</field>
        <field name="arch" type="xml">
            <search string="Device Whitelist">
                <field name="serial_number"/>
                <field name="model_number"/>
                <field name="device_vendor"/>
                <field name="device_type"/>
                <group>
                    <filter string="Device Type" name="group_type" context="{'group_by':'device_type'}"/>
                    <filter string="Vendor" name="group_vendor" context="{'group_by':'device_vendor'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="nsp_device_whitelist_list_view" model="ir.ui.view">
        <field name="name">nsp.device.whitelist.list</field>
        <field name="model">nsp.device.whitelist</field>
        <field name="arch" type="xml">
            <list string="Device Whitelist" editable="bottom">
                <field name="serial_number" string="Serial"/>
                <field name="model_number" string="Model"/>
                <field name="device_vendor" string="Vendor"/>
                <field name="device_type"/>
            </list>
        </field>
    </record>

    <record id="nsp_device_whitelist_form_view" model="ir.ui.view">
        <field name="name">nsp.device.whitelist.form</field>
        <field name="model">nsp.device.whitelist</field>
        <field name="arch" type="xml">
            <form string="Device Whitelist">
                <sheet>
                    <div class="oe_title">
                        <label for="serial_number"/>
                        <h1><field name="serial_number" placeholder="24113001"/></h1>
                    </div>
                    <div class="alert alert-info" role="alert">
                        A Serial is allowed as soon as it exists in this list. Devices not listed here are rejected and generate an NSP Notification.
                    </div>
                    <group string="Whitelist Entry">
                        <group>
                            <field name="model_number" string="Model"/>
                            <field name="device_vendor" string="Vendor"/>
                        </group>
                        <group>
                            <field name="device_type"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="nsp_device_whitelist_action" model="ir.actions.act_window">
        <field name="name">Device Whitelist</field>
        <field name="res_model">nsp.device.whitelist</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="nsp_device_whitelist_search_view"/>
    </record>
</odoo>
