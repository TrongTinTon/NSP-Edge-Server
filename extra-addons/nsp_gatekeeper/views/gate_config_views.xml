<odoo>
    <record id="view_nsp_gate_search" model="ir.ui.view">
        <field name="name">view.nsp.gate.search</field>
        <field name="model">nsp.gate</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/><field name="code"/><field name="branch_id"/><field name="controller_ids"/><field name="config_state"/>
                <filter string="Active" name="active" domain="[('gate_status','=','active')]"/>
                <filter string="Operational" name="operational" domain="[('operation_state','=','operational')]"/>
                <separator/>
                <filter string="Branch" name="group_branch" context="{'group_by':'branch_id'}"/>
                <filter string="Config State" name="group_state" context="{'group_by':'config_state'}"/>
            </search>
        </field>
    </record>

    <record id="view_nsp_gate_list" model="ir.ui.view">
        <field name="name">view.nsp.gate.list</field>
        <field name="model">nsp.gate</field>
        <field name="arch" type="xml">
            <list string="Gates">
                <field name="name"/><field name="code"/><field name="branch_id"/><field name="controller_count"/><field name="lane_count"/>
                <field name="entry_antenna_count"/><field name="exit_antenna_count"/>
                <field name="invalid_antenna_count" decoration-danger="invalid_antenna_count &gt; 0"/>
                <field name="gate_status" widget="badge" decoration-success="gate_status == 'active'" decoration-danger="gate_status == 'blocked'" decoration-warning="gate_status == 'maintenance'"/>
                <field name="operation_state" widget="badge" decoration-success="operation_state == 'operational'" decoration-muted="operation_state == 'draft'"/>
                <field name="config_state" widget="badge" decoration-success="config_state == 'applied'" decoration-warning="config_state == 'pending_sync'" decoration-danger="config_state == 'error'"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_gate_form" model="ir.ui.view">
        <field name="name">view.nsp.gate.form</field>
        <field name="model">nsp.gate</field>
        <field name="arch" type="xml">
            <form string="Gate">
                <header>
                    <button name="action_load_lane_antennas_from_controllers" type="object" class="btn btn-secondary" string="Load Antennas"/>
                    <button name="action_create_measurement_session" type="object" class="btn btn-secondary" string="New Measurement" groups="nsp_core.group_nsp_it_parking"/>
                    <button name="action_open_measurement_sessions" type="object" class="btn btn-secondary" string="Measurements"/>
                    <button name="action_set_operational" type="object" class="btn btn-primary" string="Set Operational"/>
                    <field name="config_state" widget="statusbar" statusbar_visible="draft,pending_sync,applied,error"/>
                </header>
                <sheet>
                    <div class="oe_title"><label for="name"/><h1><field name="name" placeholder="Gate 1"/></h1></div>
                    <group>
                        <group string="Gate">
                            <field name="code"/><field name="branch_id"/>
                            <field name="gate_status" widget="badge"/>
                            <field name="operation_state" widget="badge"/>
                        </group>
                        <group string="Assigned Controllers">
                            <field name="controller_ids" widget="many2many_tags"/>
                            <field name="controller_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Configuration Version">
                        <field name="config_revision" readonly="1"/><field name="config_hash" readonly="1"/>
                        <field name="last_synced_at" readonly="1"/><field name="last_applied_at" readonly="1"/><field name="apply_message" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Lanes">
                            <field name="lane_ids">
                                <list editable="bottom" string="Gate Lanes">
                                    <field name="sequence"/><field name="lane_no"/><field name="code"/><field name="name"/>
                                    <field name="lane_type"/><field name="direction" invisible="lane_type == 'two_way'"/>
                                    <field name="detection_window_ms"/><field name="required_vehicle_tid"/><field name="required_user_tid"/>
                                    <field name="active" widget="boolean_toggle"/><field name="active_antenna_count" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Antenna Groups">
                            <field name="lane_antenna_group_ids">
                                <list editable="bottom">
                                    <field name="lane_id" domain="[('gate_id','=',parent.id)]"/>
                                    <field name="direction"/><field name="detection_mode"/><field name="sequence"/><field name="active" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>
                        <page string="Antenna Mapping">
                            <field name="lane_antenna_rule_ids">
                                <list editable="bottom">
                                    <field name="antenna_group_id" domain="[('gate_id','=',parent.id)]"/>
                                    <field name="lane_id" readonly="1"/><field name="group_direction" readonly="1" widget="badge"/>
                                    <field name="detection_mode" readonly="1"/><field name="antenna_ref_id"/>
                                    <field name="serial_number" readonly="1"/><field name="antenna_no" readonly="1"/>
                                    <field name="sequence_no" invisible="detection_mode == 'any'"/>
                                    <field name="is_active" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>
                        <page string="Measurement History">
                            <field name="measurement_session_ids" readonly="1">
                                <list><field name="measurement_code"/><field name="lane_id"/><field name="planned_direction"/><field name="measurement_status" widget="badge"/><field name="apply_status" widget="badge"/><field name="started_at"/><field name="event_count"/></list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_nsp_gate_lane_list" model="ir.ui.view">
        <field name="name">view.nsp.gate.lane.list</field><field name="model">nsp.gate.lane</field>
        <field name="arch" type="xml"><list><field name="gate_id"/><field name="code"/><field name="name"/><field name="lane_no"/><field name="lane_type"/><field name="direction"/><field name="detection_window_ms"/><field name="required_vehicle_tid"/><field name="required_user_tid"/><field name="active" widget="boolean_toggle"/><field name="active_antenna_count"/></list></field>
    </record>

    <record id="view_nsp_gate_lane_form" model="ir.ui.view">
        <field name="name">view.nsp.gate.lane.form</field><field name="model">nsp.gate.lane</field>
        <field name="arch" type="xml">
            <form string="Gate Lane"><sheet>
                <div class="oe_title"><label for="name"/><h1><field name="name"/></h1></div>
                <group><group><field name="gate_id"/><field name="code"/><field name="lane_no"/><field name="lane_type"/><field name="direction" invisible="lane_type == 'two_way'"/></group>
                <group><field name="sequence"/><field name="detection_window_ms"/><field name="required_vehicle_tid"/><field name="required_user_tid"/><field name="active" widget="boolean_toggle"/></group></group>
                <notebook>
                    <page string="Antenna Groups"><field name="antenna_group_ids"><list editable="bottom"><field name="direction"/><field name="detection_mode"/><field name="sequence"/><field name="active" widget="boolean_toggle"/></list></field></page>
                    <page string="Antenna Mapping"><field name="antenna_rule_ids"><list editable="bottom"><field name="antenna_group_id" domain="[('lane_id','=',parent.id)]"/><field name="group_direction" readonly="1"/><field name="detection_mode" readonly="1"/><field name="antenna_ref_id"/><field name="serial_number" readonly="1"/><field name="antenna_no" readonly="1"/><field name="sequence_no" invisible="detection_mode == 'any'"/><field name="is_active" widget="boolean_toggle"/></list></field></page>
                    <page string="Note"><field name="note"/></page>
                </notebook>
            </sheet></form>
        </field>
    </record>

    <record id="view_nsp_gate_lane_antenna_group_list" model="ir.ui.view">
        <field name="name">view.nsp.gate.lane.antenna.group.list</field><field name="model">nsp.gate.lane.antenna.group</field>
        <field name="arch" type="xml"><list><field name="gate_id"/><field name="lane_id"/><field name="direction"/><field name="detection_mode"/><field name="sequence"/><field name="active" widget="boolean_toggle"/></list></field>
    </record>
    <record id="view_nsp_gate_lane_antenna_group_form" model="ir.ui.view">
        <field name="name">view.nsp.gate.lane.antenna.group.form</field><field name="model">nsp.gate.lane.antenna.group</field>
        <field name="arch" type="xml"><form><sheet><group><field name="lane_id"/><field name="gate_id" readonly="1"/><field name="direction"/><field name="detection_mode"/><field name="sequence"/><field name="active" widget="boolean_toggle"/></group><field name="antenna_mapping_ids"><list editable="bottom"><field name="antenna_ref_id"/><field name="serial_number" readonly="1"/><field name="antenna_no" readonly="1"/><field name="sequence_no" invisible="parent.detection_mode == 'any'"/><field name="is_active" widget="boolean_toggle"/></list></field></sheet></form></field>
    </record>

    <record id="view_nsp_gate_lane_antenna_mapping_list" model="ir.ui.view">
        <field name="name">view.nsp.gate.lane.antenna.mapping.list</field><field name="model">nsp.gate.lane.antenna.mapping</field>
        <field name="arch" type="xml"><list><field name="gate_id"/><field name="lane_id"/><field name="antenna_group_id"/><field name="group_direction"/><field name="detection_mode"/><field name="antenna_ref_id"/><field name="serial_number"/><field name="antenna_no"/><field name="sequence_no"/><field name="is_active" widget="boolean_toggle"/></list></field>
    </record>
    <record id="view_nsp_gate_lane_antenna_mapping_form" model="ir.ui.view">
        <field name="name">view.nsp.gate.lane.antenna.mapping.form</field><field name="model">nsp.gate.lane.antenna.mapping</field>
        <field name="arch" type="xml"><form><sheet><group><group><field name="antenna_group_id"/><field name="gate_id" readonly="1"/><field name="lane_id" readonly="1"/><field name="group_direction" readonly="1"/><field name="detection_mode" readonly="1"/></group><group><field name="antenna_ref_id"/><field name="controller_id" readonly="1"/><field name="serial_number" readonly="1"/><field name="antenna_no" readonly="1"/></group></group><group><field name="sequence_no" invisible="detection_mode == 'any'"/><field name="is_active" widget="boolean_toggle"/><field name="note"/></group></sheet></form></field>
    </record>

    <record id="action_nsp_gate" model="ir.actions.act_window"><field name="name">Gate</field><field name="res_model">nsp.gate</field><field name="view_mode">list,form</field></record>
    <record id="action_nsp_gate_lane" model="ir.actions.act_window"><field name="name">Gate Lanes</field><field name="res_model">nsp.gate.lane</field><field name="view_mode">list,form</field></record>
    <record id="action_nsp_gate_lane_antenna_group" model="ir.actions.act_window"><field name="name">Lane Antenna Groups</field><field name="res_model">nsp.gate.lane.antenna.group</field><field name="view_mode">list,form</field></record>
    <record id="action_nsp_gate_lane_antenna_mapping" model="ir.actions.act_window"><field name="name">Gate Lane Antenna Mapping</field><field name="res_model">nsp.gate.lane.antenna.mapping</field><field name="view_mode">list,form</field></record>
</odoo>
