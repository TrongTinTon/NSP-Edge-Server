<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ir_cron_nsp_parking_detection_process" model="ir.cron">
        <field name="name">NSP Parking Detection Processor</field>
        <field name="model_id" ref="model_nsp_parking_detection_event"/>
        <field name="state">code</field>
        <field name="code">model.process_pending_events()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
        <field name="user_id" ref="base.user_root"/>
    </record>

    <record id="ir_cron_nsp_parking_detection_cleanup" model="ir.cron">
        <field name="name">NSP Parking Detection Cleanup</field>
        <field name="model_id" ref="model_nsp_parking_detection_event"/>
        <field name="state">code</field>
        <field name="code">model.cleanup_old_events()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active">True</field>
        <field name="user_id" ref="base.user_root"/>
    </record>
</odoo>
