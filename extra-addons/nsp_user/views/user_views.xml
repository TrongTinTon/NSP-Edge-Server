<odoo>
    <record id="view_nsp_user_search" model="ir.ui.view">
        <field name="name">nsp.user.search</field>
        <field name="model">nsp.user</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="user_code" string="Technical User Code"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <filter string="Archived" name="archived" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record id="view_nsp_user_list" model="ir.ui.view">
        <field name="name">nsp.user.list</field>
        <field name="model">nsp.user</field>
        <field name="arch" type="xml">
            <list string="Users">
                <field name="active" widget="boolean_toggle"/>
                <field name="name" decoration-bf="1"/>
                <field name="phone" optional="show"/>
                <field name="email" optional="show"/>
                <field name="user_rfid_tid" string="Primary User TID" optional="show"/>
                <field name="active_user_card_count" optional="show"/>
                <field name="user_code" string="Technical Code" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_user_form" model="ir.ui.view">
        <field name="name">nsp.user.form</field>
        <field name="model">nsp.user</field>
        <field name="arch" type="xml">
            <form string="User">
                <header>
                    <button name="action_archive" type="object" string="Archive" invisible="not active" class="btn-secondary"/>
                    <button name="action_unarchive" type="object" string="Unarchive" invisible="active" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="User name"/></h1>
                    </div>
                    <group>
                        <group string="Contact">
                            <field name="active"/>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                        <group string="RFID Summary">
                            <field name="user_rfid_tid" readonly="1"/>
                            <field name="active_user_card_count" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="User Cards">
                            <field name="user_card_ids" context="{'default_user_id': id}">
                                <list editable="bottom">
                                    <field name="card_id" options="{'no_create': True}"/>
                                    <field name="tid" readonly="1"/>
                                    <field name="state" widget="badge" readonly="1" decoration-success="state == 'active'" decoration-muted="state == 'revoked'"/>
                                    <field name="assigned_at" optional="hide"/>
                                    <field name="revoked_at" readonly="1" optional="hide"/>
                                    <field name="note" optional="hide"/>
                                    <button name="action_revoke" type="object" string="Revoke" invisible="state != 'active'"/>
                                    <button name="action_activate" type="object" string="Activate" invisible="state != 'revoked'" class="btn-primary"/>
                                </list>
                            </field>
                        </page>
                        <page string="Friends">
                            <group>
                                <field name="accepted_friend_ids" widget="many2many_tags" readonly="1"/>
                            </group>
                            <separator string="Sent Requests"/>
                            <field name="friendship_sent_ids" context="{'default_requester_id': id}">
                                <list editable="bottom">
                                    <field name="addressee_id" string="Friend" domain="[('id','!=',parent.id)]"/>
                                    <field name="state" widget="badge" readonly="1"/>
                                    <field name="accepted_at" readonly="1" optional="hide"/>
                                    <button name="action_cancel" type="object" string="Cancel" invisible="state != 'pending'"/>
                                    <button name="action_cancel" type="object" string="Remove" invisible="state != 'accepted'"/>
                                </list>
                            </field>
                            <separator string="Received Requests"/>
                            <field name="friendship_received_ids">
                                <list create="0" delete="0">
                                    <field name="requester_id" string="From"/>
                                    <field name="state" widget="badge"/>
                                    <field name="accepted_at" optional="hide"/>
                                    <button name="action_accept" type="object" string="Accept" class="btn-primary" invisible="state != 'pending'"/>
                                    <button name="action_cancel" type="object" string="Decline" invisible="state != 'pending'"/>
                                    <button name="action_cancel" type="object" string="Remove" invisible="state != 'accepted'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Note">
                            <field name="note" nolabel="1"/>
                        </page>
                        <page string="Technical" groups="nsp_core.group_nsp_it_parking">
                            <group>
                                <field name="user_code" readonly="1" widget="CopyClipboardChar"/>
                                <field name="user_rfid_tids" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_nsp_user" model="ir.actions.act_window">
        <field name="name">Users</field>
        <field name="res_model">nsp.user</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_nsp_user_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>
