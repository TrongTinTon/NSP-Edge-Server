<?xml version='1.0' encoding='utf-8'?>
<odoo>
  <record id="view_nsp_user_friendship_form" model="ir.ui.view">
    <field name="name">nsp.user.friendship.form</field>
    <field name="model">nsp.user.friendship</field>
    <field name="arch" type="xml">
      <form string="Friendship">
        <header>
          <button name="action_accept" type="object" string="Accept" class="btn-primary" invisible="state == 'accepted'"/>
          <button name="action_cancel" type="object" string="Decline" invisible="state != 'pending'"/>
          <button name="action_cancel" type="object" string="Remove Friend" invisible="state != 'accepted'"/>
          <field name="state" widget="statusbar" statusbar_visible="pending,accepted" readonly="1"/>
        </header>
        <sheet>
          <group>
            <field name="requester_id" readonly="state != 'pending'"/>
            <field name="addressee_id" readonly="state != 'pending'"/>
            <field name="accepted_at" readonly="1"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>
</odoo>
