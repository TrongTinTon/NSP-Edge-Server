<?xml version='1.0' encoding='utf-8'?>
<odoo>
  <record id="view_nsp_user_card_form" model="ir.ui.view">
    <field name="name">nsp.user.card.form</field>
    <field name="model">nsp.user.card</field>
    <field name="arch" type="xml">
      <form string="User Card">
        <header>
          <button name="action_revoke" type="object" string="Revoke" invisible="state != 'active'" class="btn-secondary"/>
          <button name="action_activate" type="object" string="Activate" invisible="state != 'revoked'" class="btn-primary"/>
        </header>
        <sheet>
          <group>
            <group>
              <field name="user_id"/>
              <field name="card_id"/>
              <field name="tid" readonly="1"/>
            </group>
            <group>
              <field name="state" readonly="1"/>
              <field name="assigned_at" readonly="1"/>
              <field name="revoked_at" readonly="1"/>
            </group>
          </group>
          <field name="note" placeholder="Note..."/>
        </sheet>
      </form>
    </field>
  </record>
</odoo>
