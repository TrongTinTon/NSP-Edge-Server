<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="push_provider_in_app" model="nsp.push.provider">
        <field name="name">In-App Bus</field>
        <field name="sequence">100</field>
        <field name="provider_type">in_app</field>
        <field name="environment">production</field>
        <field name="state">ready</field>
        <field name="active" eval="True"/>
        <field name="note">Default local in-app provider using Odoo bus. Native providers such as FCM/APNs must be configured by Admin.</field>
    </record>

    <record id="push_rule_vehicle_entry_owner" model="nsp.push.rule">
        <field name="name">Vehicle Entry - Owner</field>
        <field name="sequence">10</field>
        <field name="notification_type">parking_entry</field>
        <field name="min_severity">info</field>
        <field name="recipient_scope">target_user</field>
        <field name="provider_type">any</field>
        <field name="priority">normal</field>
        <field name="active" eval="True"/>
    </record>
    <record id="push_rule_vehicle_exit_owner" model="nsp.push.rule">
        <field name="name">Vehicle Exit - Owner</field>
        <field name="sequence">20</field>
        <field name="notification_type">parking_exit</field>
        <field name="min_severity">info</field>
        <field name="recipient_scope">target_user</field>
        <field name="provider_type">any</field>
        <field name="priority">normal</field>
        <field name="active" eval="True"/>
    </record>
    <record id="push_rule_parking_denied_owner" model="nsp.push.rule">
        <field name="name">Parking Denied - Owner</field>
        <field name="sequence">30</field>
        <field name="notification_type">parking_denied</field>
        <field name="min_severity">warning</field>
        <field name="recipient_scope">target_user</field>
        <field name="provider_type">any</field>
        <field name="priority">high</field>
        <field name="active" eval="True"/>
    </record>
    <record id="push_rule_system_alert_internal" model="nsp.push.rule">
        <field name="name">Critical System Alert - Internal Users</field>
        <field name="sequence">40</field>
        <field name="notification_type">system_alert</field>
        <field name="min_severity">critical</field>
        <field name="recipient_scope">all_internal_users</field>
        <field name="provider_type">any</field>
        <field name="priority">high</field>
        <field name="active" eval="False"/>
    </record>
    <record id="push_rule_emergency_internal" model="nsp.push.rule">
        <field name="name">Emergency - Internal Users</field>
        <field name="sequence">50</field>
        <field name="notification_type">emergency</field>
        <field name="min_severity">critical</field>
        <field name="recipient_scope">all_internal_users</field>
        <field name="provider_type">any</field>
        <field name="priority">emergency</field>
        <field name="active" eval="False"/>
    </record>
</odoo>
