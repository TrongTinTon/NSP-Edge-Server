<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nsp_notification_settings" model="ir.ui.view">
        <field name="name">view.nsp.notification.settings</field>
        <field name="model">res.config.settings</field>
        <field name="arch" type="xml">
            <form string="NSP Notification Settings">
                <sheet>
                    <h2>NSP Native Push</h2>
                    <group>
                        <group string="Runtime">
                            <field name="nsp_push_enabled"/>
                            <field name="nsp_push_send_immediate"/>
                        </group>
                        <group string="Queue">
                            <field name="nsp_push_max_retry"/>
                            <field name="nsp_push_retry_delay_sec"/>
                            <field name="nsp_push_delivery_retention_days"/>
                        </group>
                    </group>
                    <footer>
                        <button string="Save" type="object" name="execute" class="btn-primary"/>
                        <button string="Cancel" special="cancel" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_nsp_notification_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_nsp_notification_settings"/>
        <field name="target">current</field>
        <field name="context">{'module': 'nsp_notification'}</field>
    </record>
</odoo>
