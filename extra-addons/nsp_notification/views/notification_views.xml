<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nsp_notification_search" model="ir.ui.view">
        <field name="name">nsp.notification.search</field>
        <field name="model">nsp.notification</field>
        <field name="arch" type="xml">
            <search string="Notifications">
                <field name="name"/>
                <field name="message"/>
                <field name="controller_code"/>
                <field name="device_serial"/>
                <filter string="Unread" name="unread" domain="[('state','=','unread')]"/>
                <filter string="Device Security" name="device_security" domain="[('category','=','device_security')]"/>
                <filter string="Critical" name="critical" domain="[('severity','=','critical')]"/>
                <separator/>
                <group>
                    <filter string="Category" name="group_category" context="{'group_by':'category'}"/>
                    <filter string="Severity" name="group_severity" context="{'group_by':'severity'}"/>
                    <filter string="State" name="group_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_nsp_notification_list" model="ir.ui.view">
        <field name="name">nsp.notification.list</field>
        <field name="model">nsp.notification</field>
        <field name="arch" type="xml">
            <list string="Notifications" create="0">
                <field name="event_time"/>
                <field name="severity" widget="badge"
                       decoration-info="severity == 'info'"
                       decoration-warning="severity == 'warning'"
                       decoration-danger="severity == 'critical'"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'unread'"
                       decoration-success="state == 'read'"
                       decoration-muted="state == 'archived'"/>
                <field name="category"/>
                <field name="name"/>
                <field name="controller_code" optional="show"/>
                <field name="device_serial" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_notification_form" model="ir.ui.view">
        <field name="name">nsp.notification.form</field>
        <field name="model">nsp.notification</field>
        <field name="arch" type="xml">
            <form string="Notification" create="0">
                <header>
                    <button name="action_mark_read" string="Mark Read" type="object" class="oe_highlight" invisible="state != 'unread'"/>
                    <button name="action_mark_unread" string="Mark Unread" type="object" invisible="state != 'read'"/>
                    <button name="action_archive" string="Archive" type="object" invisible="state == 'archived'"/>
                    <field name="state" widget="statusbar" statusbar_visible="unread,read,archived"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Alert">
                            <field name="category" readonly="1"/>
                            <field name="severity" readonly="1"/>
                            <field name="event_time" readonly="1"/>
                            <field name="message" readonly="1"/>
                        </group>
                        <group string="Device Context">
                            <field name="controller_code" readonly="1"/>
                            <field name="device_serial" readonly="1"/>
                            <field name="source_model" readonly="1"/>
                            <field name="source_record_id" readonly="1"/>
                            <field name="read_at" readonly="1"/>
                            <field name="read_by" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_nsp_notification" model="ir.actions.act_window">
        <field name="name">Notifications</field>
        <field name="res_model">nsp.notification</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_nsp_notification_search"/>
        <field name="context">{'search_default_unread': 1}</field>
    </record>
</odoo>
