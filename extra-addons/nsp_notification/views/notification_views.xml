<odoo>
    <record id="view_nsp_notification_search" model="ir.ui.view">
        <field name="name">view.nsp.notification.search</field>
        <field name="model">nsp.notification</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="message"/>
                <field name="target_user_id"/>
                <field name="recipient_user_id"/>
                <field name="vehicle_id"/>
                <field name="gate_id"/>
                <field name="controller_id"/>
                <filter string="Unread" name="unread" domain="[('state','=','unread')]"/>
                <filter string="Parking" name="parking" domain="[('notification_type','in',('parking_entry','parking_exit','parking_denied'))]"/>
                <filter string="Parking Monitor" name="parking_monitor" domain="[('monitor_channel','=','parking_monitor')]"/>
                <filter string="System Alerts" name="system_alert" domain="[('notification_type','in',('system_alert','emergency'))]"/>
                <filter string="Critical" name="critical" domain="[('severity','=','critical')]"/>
                <separator/>
                    <filter string="Type" name="group_type" context="{'group_by':'notification_type'}"/>
                    <filter string="Severity" name="group_severity" context="{'group_by':'severity'}"/>
                    <filter string="State" name="group_state" context="{'group_by':'state'}"/>
                    <filter string="Monitor Channel" name="group_monitor_channel" context="{'group_by':'monitor_channel'}"/>
                    <filter string="NSP User" name="group_user" context="{'group_by':'target_user_id'}"/>
                </search>
        </field>
    </record>

    <record id="view_nsp_notification_list" model="ir.ui.view">
        <field name="name">view.nsp.notification.list</field>
        <field name="model">nsp.notification</field>
        <field name="arch" type="xml">
            <list string="NSP Notifications">
                <field name="event_time"/>
                <field name="severity" widget="badge" decoration-info="severity == 'info'" decoration-warning="severity == 'warning'" decoration-danger="severity == 'critical'"/>
                <field name="state" widget="badge" decoration-success="state == 'read'" decoration-info="state == 'unread'" decoration-muted="state == 'archived'"/>
                <field name="push_status" widget="badge" optional="show"/>
                <field name="notification_type"/>
                <field name="monitor_channel" optional="hide"/>
                <field name="name"/>
                <field name="target_user_id" optional="show"/>
                <field name="vehicle_id" optional="show"/>
                <field name="gate_id" optional="show"/>
                <field name="controller_id" optional="hide"/>
                <field name="push_delivery_count" optional="show"/>
                <field name="push_failed_count" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_notification_form" model="ir.ui.view">
        <field name="name">view.nsp.notification.form</field>
        <field name="model">nsp.notification</field>
        <field name="arch" type="xml">
            <form string="NSP Notification">
                <header>
                    <button name="action_mark_read" string="Mark Read" type="object" class="btn-primary" invisible="state != 'unread'"/>
                    <button name="action_mark_unread" string="Mark Unread" type="object" invisible="state != 'read'"/>
                    <button name="action_prepare_push_deliveries" string="Prepare Push" type="object"/>
                    <button name="action_send_push_now" string="Send Push Now" type="object" class="btn-secondary"/>
                    <button name="action_archive" string="Archive" type="object" invisible="state == 'archived'"/>
                    <field name="state" widget="statusbar" statusbar_visible="unread,read,archived"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Notification title"/></h1>
                    </div>
                    <group>
                        <group string="Notification">
                            <field name="notification_type"/>
                            <field name="monitor_channel"/>
                            <field name="severity"/>
                            <field name="event_time"/>
                            <field name="message"/>
                        </group>
                        <group string="Recipient">
                            <field name="target_user_id"/>
                            <field name="recipient_user_id"/>
                            <field name="read_at" readonly="1"/>
                            <field name="read_by" readonly="1"/>
                        </group>
                    </group>
                    <group string="Related NSP Record">
                        <field name="parking_transaction_id" readonly="1"/>
                        <field name="vehicle_id" readonly="1"/>
                        <field name="gate_id" readonly="1"/>
                        <field name="branch_id" readonly="1"/>
                        <field name="controller_id" readonly="1"/>
                        <field name="source_model" readonly="1"/>
                        <field name="source_record_id" readonly="1"/>
                        <field name="dedupe_key" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Push Deliveries">
                            <field name="push_delivery_ids" readonly="1">
                                <list>
                                    <field name="device_id"/>
                                    <field name="provider_type"/>
                                    <field name="priority"/>
                                    <field name="status"/>
                                    <field name="attempt_count"/>
                                    <field name="sent_at"/>
                                    <field name="error_code"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nsp_notification" model="ir.actions.act_window">
        <field name="name">Notifications</field>
        <field name="res_model">nsp.notification</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
