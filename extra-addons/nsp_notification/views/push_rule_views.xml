<odoo>
    <record id="view_nsp_push_rule_search" model="ir.ui.view">
        <field name="name">view.nsp.push.rule.search</field>
        <field name="model">nsp.push.rule</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="branch_id"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <filter string="Inactive" name="inactive" domain="[('active','=',False)]"/>
                <separator/>
                    <filter string="Type" name="group_type" context="{'group_by':'notification_type'}"/>
                    <filter string="Scope" name="group_scope" context="{'group_by':'recipient_scope'}"/>
                    <filter string="Provider" name="group_provider" context="{'group_by':'provider_type'}"/>
                    <filter string="Branch" name="group_branch" context="{'group_by':'branch_id'}"/>
                </search>
        </field>
    </record>
    <record id="view_nsp_push_rule_list" model="ir.ui.view">
        <field name="name">view.nsp.push.rule.list</field>
        <field name="model">nsp.push.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active"/>
                <field name="notification_type"/>
                <field name="min_severity"/>
                <field name="recipient_scope"/>
                <field name="provider_type"/>
                <field name="priority"/>
                <field name="branch_id"/>
            </list>
        </field>
    </record>
    <record id="view_nsp_push_rule_form" model="ir.ui.view">
        <field name="name">view.nsp.push.rule.form</field>
        <field name="model">nsp.push.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><label for="name"/><h1><field name="name"/></h1></div>
                    <group>
                        <group string="Match">
                            <field name="active"/>
                            <field name="sequence"/>
                            <field name="notification_type"/>
                            <field name="min_severity"/>
                            <field name="branch_id"/>
                        </group>
                        <group string="Recipient">
                            <field name="recipient_scope"/>
                            <field name="manual_user_ids" widget="many2many_tags" invisible="recipient_scope != 'manual_users'"/>
                            <field name="provider_type"/>
                            <field name="priority"/>
                        </group>
                    </group>
                    <field name="note"/>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_nsp_push_rule" model="ir.actions.act_window">
        <field name="name">Push Rules</field>
        <field name="res_model">nsp.push.rule</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>
