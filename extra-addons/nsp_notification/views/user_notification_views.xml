<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nsp_user_form_notification_inherit" model="ir.ui.view">
        <field name="name">view.nsp.user.form.notification.inherit</field>
        <field name="model">nsp.user</field>
        <field name="inherit_id" ref="nsp_user.view_nsp_user_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group" position="after">
                <group string="Notifications">
                    <field name="notification_enabled"/>
                    <field name="notification_user_id" options="{'no_create': True}"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
