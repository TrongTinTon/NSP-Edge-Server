<odoo>
    <record id="view_nsp_push_delivery_search" model="ir.ui.view">
        <field name="name">view.nsp.push.delivery.search</field>
        <field name="model">nsp.push.delivery</field>
        <field name="arch" type="xml">
            <search>
                <field name="notification_id"/>
                <field name="device_id"/>
                <field name="target_user_id"/>
                <field name="recipient_user_id"/>
                <field name="provider_message_id"/>
                <filter string="Queued" name="queued" domain="[('status','=','queued')]"/>
                <filter string="Failed" name="failed" domain="[('status','=','failed')]"/>
                <separator/>
                    <filter string="Status" name="group_status" context="{'group_by':'status'}"/>
                    <filter string="Provider" name="group_provider" context="{'group_by':'provider_type'}"/>
                    <filter string="Priority" name="group_priority" context="{'group_by':'priority'}"/>
                </search>
        </field>
    </record>
    <record id="view_nsp_push_delivery_list" model="ir.ui.view">
        <field name="name">view.nsp.push.delivery.list</field>
        <field name="model">nsp.push.delivery</field>
        <field name="arch" type="xml">
            <list>
                <field name="notification_id"/>
                <field name="device_id"/>
                <field name="provider_type"/>
                <field name="priority"/>
                <field name="status" widget="badge" decoration-success="status in ('sent','delivered','acked','read')" decoration-warning="status in ('queued','sending')" decoration-danger="status == 'failed'" decoration-muted="status in ('expired','cancelled')"/>
                <field name="attempt_count"/>
                <field name="sent_at"/>
                <field name="next_retry_at"/>
                <field name="error_code"/>
            </list>
        </field>
    </record>
    <record id="view_nsp_push_delivery_form" model="ir.ui.view">
        <field name="name">view.nsp.push.delivery.form</field>
        <field name="model">nsp.push.delivery</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_send_now" string="Send Now" type="object" class="btn-primary" invisible="status not in ('queued','failed')"/>
                    <button name="action_mark_acked" string="Mark Acked" type="object" invisible="status not in ('sent','delivered')"/>
                    <button name="action_mark_read" string="Mark Read" type="object" invisible="status == 'read'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="status in ('sent','delivered','acked','read','cancelled')"/>
                    <field name="status" widget="statusbar" statusbar_visible="queued,sending,sent,acked,read,failed"/>
                </header>
                <sheet>
                    <group>
                        <group string="Notification">
                            <field name="notification_id"/>
                            <field name="target_user_id"/>
                            <field name="recipient_user_id"/>
                        </group>
                        <group string="Delivery">
                            <field name="device_id"/>
                            <field name="provider_id"/>
                            <field name="provider_type"/>
                            <field name="priority"/>
                        </group>
                    </group>
                    <group>
                        <group string="Retry">
                            <field name="attempt_count" readonly="1"/>
                            <field name="max_retry"/>
                            <field name="next_retry_at" readonly="1"/>
                        </group>
                        <group string="Timestamps">
                            <field name="sent_at" readonly="1"/>
                            <field name="delivered_at" readonly="1"/>
                            <field name="acked_at" readonly="1"/>
                            <field name="read_at" readonly="1"/>
                        </group>
                    </group>
                    <group string="Provider Result">
                        <field name="provider_message_id" readonly="1"/>
                        <field name="error_code" readonly="1"/>
                        <field name="error_message" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_nsp_push_delivery" model="ir.actions.act_window">
        <field name="name">Push Deliveries</field>
        <field name="res_model">nsp.push.delivery</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
