<odoo>
    <record id="view_nsp_push_provider_search" model="ir.ui.view">
        <field name="name">view.nsp.push.provider.search</field>
        <field name="model">nsp.push.provider</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="project_id"/>
                <field name="secret_param_key"/>
                <filter string="Ready" name="ready" domain="[('state','=','ready'),('active','=',True)]"/>
                <filter string="Inactive" name="inactive" domain="['|',('active','=',False),('state','=','disabled')]"/>
                <separator/>
                    <filter string="Provider" name="group_provider" context="{'group_by':'provider_type'}"/>
                    <filter string="Environment" name="group_environment" context="{'group_by':'environment'}"/>
                    <filter string="State" name="group_state" context="{'group_by':'state'}"/>
                </search>
        </field>
    </record>
    <record id="view_nsp_push_provider_list" model="ir.ui.view">
        <field name="name">view.nsp.push.provider.list</field>
        <field name="model">nsp.push.provider</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="provider_type"/>
                <field name="environment"/>
                <field name="state" widget="badge" decoration-success="state == 'ready'" decoration-warning="state == 'draft'" decoration-muted="state == 'disabled'"/>
                <field name="active"/>
                <field name="project_id"/>
                <field name="last_success_at"/>
                <field name="last_failure_at"/>
                <field name="last_error" optional="hide"/>
            </list>
        </field>
    </record>
    <record id="view_nsp_push_provider_form" model="ir.ui.view">
        <field name="name">view.nsp.push.provider.form</field>
        <field name="model">nsp.push.provider</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_ready" string="Mark Ready" type="object" class="btn-primary" invisible="state == 'ready'"/>
                    <button name="action_disable" string="Disable" type="object" invisible="state == 'disabled'"/>
                    <button name="action_test_provider" string="Check Config" type="object"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,ready,disabled"/>
                </header>
                <sheet>
                    <div class="oe_title"><label for="name"/><h1><field name="name"/></h1></div>
                    <group>
                        <group string="Provider">
                            <field name="active"/>
                            <field name="sequence"/>
                            <field name="provider_type"/>
                            <field name="environment"/>
                            <field name="timeout_sec"/>
                        </group>
                        <group string="Endpoint / Secret">
                            <field name="endpoint_url"/>
                            <field name="secret_param_key"/>
                            <field name="auth_mode" invisible="provider_type != 'fcm'"/>
                            <field name="project_id" invisible="provider_type != 'fcm'"/>
                        </group>
                    </group>
                    <group string="APNs" invisible="provider_type != 'apns'">
                        <field name="apns_team_id"/>
                        <field name="apns_key_id"/>
                        <field name="apns_bundle_id"/>
                    </group>
                    <group string="Status">
                        <field name="last_success_at" readonly="1"/>
                        <field name="last_failure_at" readonly="1"/>
                        <field name="last_error" readonly="1"/>
                    </group>
                    <field name="note"/>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_nsp_push_provider" model="ir.actions.act_window">
        <field name="name">Push Providers</field>
        <field name="res_model">nsp.push.provider</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
