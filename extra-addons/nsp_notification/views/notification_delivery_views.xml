<odoo>
    <record id="view_nsp_notification_delivery_list" model="ir.ui.view">
        <field name="name">nsp.notification.delivery.list</field>
        <field name="model">nsp.notification.delivery</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0">
                <field name="notification_id"/>
                <field name="recipient_user_id"/>
                <field name="device_uid"/>
                <field name="channel" widget="badge"/>
                <field name="provider"/>
                <field name="state" widget="badge" decoration-success="state == 'delivered'" decoration-warning="state == 'pending'" decoration-danger="state == 'failed'"/>
                <field name="attempt_count" optional="hide"/>
                <field name="sent_at" optional="show"/>
                <field name="delivered_at" optional="show"/>
                <field name="last_error" optional="hide"/>
            </list>
        </field>
    </record>
    <record id="action_nsp_notification_delivery" model="ir.actions.act_window">
        <field name="name">Deliveries</field>
        <field name="res_model">nsp.notification.delivery</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
