<odoo>
    <record id="view_nsp_push_device_search" model="ir.ui.view">
        <field name="name">view.nsp.push.device.search</field>
        <field name="model">nsp.push.device</field>
        <field name="arch" type="xml">
            <search>
                <field name="display_name"/>
                <field name="device_uid"/>
                <field name="user_id"/>
                <field name="odoo_user_id"/>
                <field name="push_token_hash"/>
                <filter string="Active" name="active" domain="[('status','=','active')]"/>
                <filter string="Revoked" name="revoked" domain="[('status','=','revoked')]"/>
                <separator/>
                    <filter string="Platform" name="group_platform" context="{'group_by':'platform'}"/>
                    <filter string="Provider" name="group_provider_type" context="{'group_by':'provider_type'}"/>
                    <filter string="Status" name="group_status" context="{'group_by':'status'}"/>
                </search>
        </field>
    </record>
    <record id="view_nsp_push_device_list" model="ir.ui.view">
        <field name="name">view.nsp.push.device.list</field>
        <field name="model">nsp.push.device</field>
        <field name="arch" type="xml">
            <list>
                <field name="display_name"/>
                <field name="platform"/>
                <field name="provider_type"/>
                <field name="provider_id"/>
                <field name="status" widget="badge" decoration-success="status == 'active'" decoration-muted="status == 'inactive'" decoration-danger="status == 'revoked'"/>
                <field name="notification_enabled"/>
                <field name="app_version"/>
                <field name="last_seen_at"/>
                <field name="delivery_count"/>
            </list>
        </field>
    </record>
    <record id="view_nsp_push_device_form" model="ir.ui.view">
        <field name="name">view.nsp.push.device.form</field>
        <field name="model">nsp.push.device</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_activate" string="Activate" type="object" class="btn-primary" invisible="status == 'active'"/>
                    <button name="action_revoke" string="Revoke" type="object" invisible="status == 'revoked'"/>
                    <field name="status" widget="statusbar" statusbar_visible="active,inactive,revoked"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="display_name" readonly="1"/></h1></div>
                    <group>
                        <group string="Owner">
                            <field name="user_id"/>
                            <field name="odoo_user_id"/>
                            <field name="notification_enabled"/>
                        </group>
                        <group string="Device">
                            <field name="device_uid"/>
                            <field name="platform"/>
                            <field name="app_version"/>
                            <field name="registered_at" readonly="1"/>
                            <field name="last_seen_at"/>
                            <field name="revoked_at" readonly="1"/>
                        </group>
                    </group>
                    <group string="Push">
                        <field name="provider_type"/>
                        <field name="provider_id"/>
                        <field name="push_token_hash" readonly="1"/>
                        <field name="push_token" password="True" groups="base.group_system"/>
                    </group>
                    <field name="note" placeholder="Internal note"/>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_nsp_push_device" model="ir.actions.act_window">
        <field name="name">Push Devices</field>
        <field name="res_model">nsp.push.device</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>
