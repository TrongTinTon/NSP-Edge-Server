<odoo>
    <record id="view_nsp_mobile_device_search" model="ir.ui.view">
        <field name="name">nsp.mobile.device.search</field>
        <field name="model">nsp.mobile.device</field>
        <field name="arch" type="xml">
            <search>
                <field name="user_id"/>
                <field name="device_name"/>
                <field name="device_uid"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <filter string="Push Enabled" name="push" domain="[('push_enabled','=',True)]"/>
            </search>
        </field>
    </record>
    <record id="view_nsp_mobile_device_list" model="ir.ui.view">
        <field name="name">nsp.mobile.device.list</field>
        <field name="model">nsp.mobile.device</field>
        <field name="arch" type="xml">
            <list create="0" delete="0">
                <field name="active" widget="boolean_toggle"/>
                <field name="user_id"/>
                <field name="device_name"/>
                <field name="platform" widget="badge"/>
                <field name="app_version"/>
                <field name="push_provider" widget="badge"/>
                <field name="push_enabled"/>
                <field name="last_seen_at"/>
                <field name="device_uid" optional="hide"/>
            </list>
        </field>
    </record>
    <record id="view_nsp_mobile_device_form" model="ir.ui.view">
        <field name="name">nsp.mobile.device.form</field>
        <field name="model">nsp.mobile.device</field>
        <field name="arch" type="xml">
            <form create="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="user_id" readonly="1"/>
                            <field name="device_name"/>
                            <field name="platform" readonly="1"/>
                            <field name="app_version" readonly="1"/>
                        </group>
                        <group string="Delivery">
                            <field name="push_provider" readonly="1"/>
                            <field name="push_enabled" readonly="1"/>
                            <field name="active"/>
                            <field name="last_seen_at" readonly="1"/>
                            <field name="last_sync_at" readonly="1"/>
                        </group>
                    </group>
                    <group string="Technical" groups="nsp_core.group_nsp_it_parking,base.group_system">
                        <field name="device_uid" readonly="1" widget="CopyClipboardChar"/>
                        <field name="push_token" readonly="1" password="True"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_nsp_mobile_device" model="ir.actions.act_window">
        <field name="name">Devices</field>
        <field name="res_model">nsp.mobile.device</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_nsp_mobile_device_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>
