<odoo>
    <record id="view_nsp_mobile_session_list" model="ir.ui.view">
        <field name="name">nsp.mobile.session.list</field>
        <field name="model">nsp.mobile.session</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0" decoration-muted="state == 'revoked'">
                <field name="user_id"/>
                <field name="device_id"/>
                <field name="state" widget="badge" decoration-success="state == 'active'" decoration-muted="state == 'revoked'"/>
                <field name="last_seen_at"/>
                <field name="last_ip" optional="hide"/>
                <field name="create_date" string="Started At"/>
                <field name="revoked_at" optional="hide"/>
                <field name="session_uid" optional="hide"/>
                <button name="revoke" type="object" string="Revoke" invisible="state != 'active'" class="btn-secondary"/>
            </list>
        </field>
    </record>
    <record id="action_nsp_mobile_session" model="ir.actions.act_window">
        <field name="name">Sessions</field>
        <field name="res_model">nsp.mobile.session</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
