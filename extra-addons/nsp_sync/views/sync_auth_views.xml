<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nsp_sync_auth_search" model="ir.ui.view">
        <field name="name">nsp.sync.auth.search</field>
        <field name="model">nsp.sync.auth</field>
        <field name="arch" type="xml">
            <search>
                <field name="edge_server_code"/>
                <field name="remote_server_url"/>
                <field name="client_id"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <filter string="Connected" name="connected" domain="[('connected','=',True)]"/>
            </search>
        </field>
    </record>

    <record id="view_nsp_sync_auth_list" model="ir.ui.view">
        <field name="name">nsp.sync.auth.list</field>
        <field name="model">nsp.sync.auth</field>
        <field name="arch" type="xml">
            <list string="Cloud Connections">
                <field name="sequence" widget="handle"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="edge_server_code"/>
                <field name="remote_base_url" string="Cloud Server"/>
                <field name="client_id" optional="show"/>
                <field name="connected" widget="boolean_toggle" readonly="1"/>
                <field name="last_auth_at" optional="show"/>
                <field name="job_count"/>
                <button name="action_authenticate" type="object" string="Authenticate" class="btn btn-primary" icon="fa-key"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_sync_auth_form" model="ir.ui.view">
        <field name="name">nsp.sync.auth.form</field>
        <field name="model">nsp.sync.auth</field>
        <field name="arch" type="xml">
            <form string="Cloud Connection">
                <header>
                    <button name="action_authenticate" type="object" string="Authenticate" class="btn-primary"/>
                    <button name="action_view_jobs" type="object" string="Sync Jobs" class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Enter a Cloud URL reachable from the Edge runtime. In Docker, do not use localhost for another container. Use the Cloud service name, host LAN IP, or host.docker.internal when Cloud is published on the Docker host.
                    </div>
                    <group>
                        <group string="Edge Server">
                            <field name="edge_server_code" widget="CopyClipboardChar"/>
                            <field name="active"/>
                        </group>
                        <group string="Cloud Core API">
                            <field name="remote_server_url" placeholder="http://cloud-web:8069 or https://cloud.example.com"/>
                            <field name="client_id"/>
                            <field name="client_secret" password="True"/>
                        </group>
                    </group>
                    <group string="Connection Status">
                        <group>
                            <field name="connected" readonly="1"/>
                            <field name="remote_base_url" readonly="1" widget="CopyClipboardChar"/>
                        </group>
                        <group>
                            <field name="last_auth_at" readonly="1"/>
                            <field name="token_expiry" readonly="1"/>
                            <field name="refresh_token_expiry" readonly="1"/>
                            <field name="job_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Last Error" invisible="not last_error">
                        <field name="last_error" nolabel="1" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nsp_sync_auth" model="ir.actions.act_window">
        <field name="name">Cloud Connections</field>
        <field name="res_model">nsp.sync.auth</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>
