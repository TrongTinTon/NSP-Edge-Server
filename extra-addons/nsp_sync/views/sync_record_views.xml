<odoo>
    <record id="view_nsp_sync_record_search" model="ir.ui.view">
        <field name="name">nsp.sync.record.search</field>
        <field name="model">nsp.sync.record</field>
        <field name="arch" type="xml">
            <search string="Sync Records">
                <field name="source_code"/>
                <field name="sync_job_id"/>
                <field name="sync_action_name"/>
                <field name="record_key"/>
                <field name="status"/>
                <field name="operation"/>
                <filter string="Pull Responses" name="pull_responses" domain="[('operation','=','pull')]"/>
                <filter string="Push Requests" name="push_requests" domain="[('operation','=','push')]"/>
                <separator/>
                <filter string="Pending" name="pending" domain="[('status','=','pending')]"/>
                <filter string="Failed" name="failed" domain="[('status','=','failed')]"/>
                <filter string="Synced" name="synced" domain="[('status','=','synced')]"/>
                <group>
                    <filter string="Source" name="group_source" context="{'group_by':'source_code'}"/>
                    <filter string="Job" name="group_job" context="{'group_by':'sync_job_id'}"/>
                    <filter string="Action" name="group_action" context="{'group_by':'sync_action_code'}"/>
                    <filter string="Operation" name="group_operation" context="{'group_by':'operation'}"/>
                    <filter string="Status" name="group_status" context="{'group_by':'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_nsp_sync_record_list" model="ir.ui.view">
        <field name="name">nsp.sync.record.list</field>
        <field name="model">nsp.sync.record</field>
        <field name="arch" type="xml">
            <list string="Sync Records" create="0" edit="0">
                <field name="source_code"/>
                <field name="sync_job_id" optional="show"/>
                <field name="sync_action_name"/>
                <field name="operation" widget="badge"/>
                <field name="record_key"/>
                <field name="status" widget="badge" decoration-success="status == 'synced'" decoration-danger="status == 'failed'" decoration-warning="status == 'pending'"/>
                <field name="attempts" optional="show"/>
                <field name="last_attempt_at" optional="show"/>
                <field name="last_synced_at" optional="show"/>
                <field name="message" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_sync_record_form" model="ir.ui.view">
        <field name="name">nsp.sync.record.form</field>
        <field name="model">nsp.sync.record</field>
        <field name="arch" type="xml">
            <form string="Sync Record" create="0" edit="0">
                <sheet>
                    <group>
                        <group string="Execution">
                            <field name="source_code"/>
                            <field name="sync_job_id"/>
                            <field name="sync_action_id"/>
                            <field name="sync_action_code"/>
                            <field name="sync_action_name"/>
                            <field name="route_suffix"/>
                            <field name="operation"/>
                        </group>
                        <group string="Record">
                            <field name="record_model"/>
                            <field name="record_id"/>
                            <field name="record_display_name"/>
                            <field name="record_key"/>
                            <field name="status" widget="badge"/>
                            <field name="attempts" invisible="operation != 'push'"/>
                            <field name="last_attempt_at" invisible="operation != 'push'"/>
                            <field name="last_synced_at"/>
                        </group>
                    </group>
                    <group string="Message"><field name="message" nolabel="1"/></group>
                    <notebook>
                        <page string="Request Payload"><field name="payload_json" nolabel="1" widget="text"/></page>
                        <page string="Response Payload"><field name="response_json" nolabel="1" widget="text"/></page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nsp_sync_record_all" model="ir.actions.act_window">
        <field name="name">Sync Records</field>
        <field name="res_model">nsp.sync.record</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_nsp_sync_record_search"/>
    </record>
</odoo>
