<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="t4_custom_dashboard.SaveDashboardDialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fa fa-save me-2"/>
                        Save Dashboard
                    </h5>
                    <button type="button" class="btn-close" t-on-click="props.onCancel"/>
                </div>
                
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Dashboard Name *</label>
                        <input type="text" 
                               class="form-control" 
                               t-model="state.name"
                               placeholder="Enter dashboard name"/>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" 
                                  t-model="state.description"
                                  rows="3"
                                  placeholder="Optional description"/>
                    </div>

                    <t t-if="props.currentDashboardId">
                        <div class="form-check">
                            <input class="form-check-input" 
                                   type="checkbox" 
                                   id="saveAsNew"
                                   t-model="state.saveAsNew"/>
                            <label class="form-check-label" for="saveAsNew">
                                Save as new dashboard (create copy)
                            </label>
                        </div>
                    </t>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" t-on-click="props.onCancel">
                        <i class="fa fa-times"/> Cancel
                    </button>
                    <button type="button" class="btn btn-primary" t-on-click="validateAndSave">
                        <i class="fa fa-save"/> Save
                    </button>
                </div>
            </div>
        </div>
    </t>
</templates>