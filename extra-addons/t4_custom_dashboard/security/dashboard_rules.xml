<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_custom_dashboard_user" model="ir.rule">
        <field name="name">Dashboard: own or shared</field>
        <field name="model_id" ref="model_custom_dashboard"/>
        <field name="groups" eval="[(4, ref('t4_custom_dashboard.group_dashboard_user'))]"/>
        <field name="domain_force">['|', ('user_id', '=', user.id), ('is_shared', '=', True)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_custom_dashboard_manager" model="ir.rule">
        <field name="name">Dashboard Manager: all dashboards</field>
        <field name="model_id" ref="model_custom_dashboard"/>
        <field name="groups" eval="[(4, ref('t4_custom_dashboard.group_dashboard_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>
