<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="privilege_dashboard" model="res.groups.privilege">
        <field name="name">Custom Dashboard</field>
        <field name="category_id" ref="base.module_category_hidden"/>
    </record>

    <record id="group_dashboard_user" model="res.groups">
        <field name="name">Dashboard User</field>
        <field name="privilege_id" ref="privilege_dashboard"/>
        <field name="sequence">10</field>
    </record>

    <record id="group_dashboard_manager" model="res.groups">
        <field name="name">Dashboard Manager</field>
        <field name="privilege_id" ref="privilege_dashboard"/>
        <field name="sequence">20</field>
        <field name="implied_ids" eval="[(4, ref('t4_custom_dashboard.group_dashboard_user'))]"/>
    </record>
</odoo>
