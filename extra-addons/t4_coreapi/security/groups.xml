<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_core_api" model="ir.module.category">
        <field name="name">Core API</field>
        <field name="sequence">50</field>
    </record>

    <record id="privilege_core_api" model="res.groups.privilege">
        <field name="name">Core API</field>
        <field name="category_id" ref="module_category_core_api"/>
    </record>

    <record id="group_core_api_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_core_api"/>
        <field name="sequence">10</field>
        <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

</odoo>
