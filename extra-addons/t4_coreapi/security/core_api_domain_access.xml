<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="access_core_api_domain_manager" model="ir.model.access">
        <field name="name">core.api.domain manager</field>
        <field name="model_id" search="[('model', '=', 'core.api.domain')]"/>
        <field name="group_id" ref="t4_coreapi.group_core_api_manager"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

    <record id="access_core_api_domain_user" model="ir.model.access">
        <field name="name">core.api.domain user</field>
        <field name="model_id" search="[('model', '=', 'core.api.domain')]"/>
        <field name="group_id" ref="base.group_user"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

</odoo>
