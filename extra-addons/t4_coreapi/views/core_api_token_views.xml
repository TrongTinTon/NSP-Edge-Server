<odoo>

    <record id="view_core_api_token_search" model="ir.ui.view">
        <field name="name">core.api.token.search</field>
        <field name="model">core.api.token</field>
        <field name="arch" type="xml">
            <search>
                <field name="application_name"/>
                <field name="service_code"/>
                <field name="client_id"/>
                <filter string="Active" name="filter_active" domain="[('token_state', '=', 'active')]"/>
                <filter string="Revoked" name="filter_revoked" domain="[('token_state', '=', 'revoked')]"/>
                <separator/>
                <filter string="Access" name="filter_access" domain="[('token_type', '=', 'access')]"/>
                <filter string="Refresh" name="filter_refresh" domain="[('token_type', '=', 'refresh')]"/>
                <separator/>
                    <filter string="Application" name="group_application" context="{'group_by': 'application_id'}"/>
                    <filter string="Type" name="group_type" context="{'group_by': 'token_type'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'token_state'}"/>
                    <filter string="Traffic Status" name="group_traffic" context="{'group_by': 'traffic_status'}"/>
                </search>
        </field>
    </record>

    <record id="view_core_api_token_list" model="ir.ui.view">
        <field name="name">core.api.token.list</field>
        <field name="model">core.api.token</field>
        <field name="arch" type="xml">
            <list decoration-muted="token_state == 'revoked'" decoration-danger="traffic_status == 'suspicious' and token_state == 'active'">
                <field name="application_name"/>
                <field name="service_code" optional="show"/>
                <field name="token_type"/>
                <field name="token_state" widget="badge" decoration-success="token_state == 'active'" decoration-muted="token_state == 'revoked'"/>
                <field name="traffic_status" widget="badge" decoration-success="traffic_status == 'normal'" decoration-warning="traffic_status == 'elevated'" decoration-danger="traffic_status == 'suspicious'"/>
                <field name="api_requests_per_minute"/>
                <field name="rate_limit_per_minute" optional="hide"/>
                <field name="auth_requests_per_minute" optional="hide"/>
                <field name="auth_rate_limit_per_minute" optional="hide"/>
                <field name="create_date" string="Issued At"/>
                <field name="active" column_invisible="1"/>
                <field name="application_state" column_invisible="1"/>
                <button name="action_revoke" type="object" string="Revoke" invisible="token_state == 'revoked'" groups="t4_coreapi.group_core_api_manager"/>
            </list>
        </field>
    </record>

    <record id="view_core_api_token_form" model="ir.ui.view">
        <field name="name">core.api.token.form</field>
        <field name="model">core.api.token</field>
        <field name="arch" type="xml">
            <form string="Access Token" create="false" edit="false">
                <header>
                    <button name="action_revoke" type="object" string="Revoke Token Pair" class="btn-warning" invisible="token_state == 'revoked'" groups="t4_coreapi.group_core_api_manager"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Revoked" bg_color="text-bg-danger" invisible="token_state == 'active'"/>
                    <widget name="web_ribbon" title="Suspicious Traffic" bg_color="text-bg-warning" invisible="traffic_status != 'suspicious' or token_state == 'revoked'"/>
                    <div class="alert alert-warning mb-3" role="alert" invisible="traffic_status != 'suspicious' or token_state == 'revoked'">
                        This application's request rate exceeded its limit. Revoke the token pair
                        if the activity looks unauthorized.
                    </div>
                    <group>
                        <group string="Application">
                            <field name="application_id"/>
                            <field name="service_code"/>
                            <field name="client_id"/>
                            <field name="application_state" widget="badge" decoration-success="application_state == 'active'" decoration-muted="application_state == 'inactive'"/>
                        </group>
                        <group string="Application Status">
                            <field name="token_state" widget="badge" decoration-success="token_state == 'active'" decoration-muted="token_state == 'revoked'"/>
                            <field name="traffic_status" widget="badge" decoration-success="traffic_status == 'normal'" decoration-warning="traffic_status == 'elevated'" decoration-danger="traffic_status == 'suspicious'"/>
                            <label for="api_requests_per_minute" string="API Requests (last min)"/>
                            <div class="o_row">
                                <field name="api_requests_per_minute" readonly="1" nolabel="1"/>
                                <span class="mx-1 text-muted">/</span>
                                <field name="rate_limit_per_minute" readonly="1" nolabel="1"/>
                            </div>
                            <label for="auth_requests_per_minute" string="Auth Requests (last min)"/>
                            <div class="o_row">
                                <field name="auth_requests_per_minute" readonly="1" nolabel="1"/>
                                <span class="mx-1 text-muted">/</span>
                                <field name="auth_rate_limit_per_minute" readonly="1" nolabel="1"/>
                            </div>
                        </group>
                    </group>
                    <group string="Token Pair">
                        <group>
                            <field name="token_type"/>
                            <field name="create_date" string="Issued At"/>
                        </group>
                        <group>
                            <field name="token_pair_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_core_api_token" model="ir.actions.act_window">
        <field name="name">Access Tokens</field>
        <field name="res_model">core.api.token</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'active_test': False}</field>
    </record>

</odoo>
