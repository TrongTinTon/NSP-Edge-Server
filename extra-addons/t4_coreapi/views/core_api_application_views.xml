<odoo>

    <record id="view_core_api_application_search" model="ir.ui.view">
        <field name="name">core.api.application.search</field>
        <field name="model">core.api.application</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="client_id"/>
                <field name="domain_id"/>
                <filter string="Active" name="filter_active" domain="[('state', '=', 'active')]"/>
                <filter string="Inactive" name="filter_inactive" domain="[('state', '=', 'inactive')]"/>
            </search>
        </field>
    </record>

    <record id="view_core_api_application_list" model="ir.ui.view">
        <field name="name">core.api.application.list</field>
        <field name="model">core.api.application</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="domain_id"/>
                <field name="client_id"/>
                <field name="state" widget="badge" decoration-success="state == 'active'" decoration-muted="state == 'inactive'"/>
                <field name="traffic_status" widget="badge" decoration-success="traffic_status == 'normal'" decoration-warning="traffic_status == 'elevated'" decoration-danger="traffic_status == 'suspicious'"/>
                <field name="api_requests_per_minute"/>
                <field name="rate_limit_per_minute" optional="hide"/>
                <field name="has_active_token" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_core_api_application_form" model="ir.ui.view">
        <field name="name">core.api.application.form</field>
        <field name="model">core.api.application</field>
        <field name="arch" type="xml">
            <form string="API Application">
                <header>
                    <button name="action_set_active" type="object" string="Activate" class="oe_highlight" invisible="state == 'active'" groups="t4_coreapi.group_core_api_manager"/>
                    <button name="action_set_inactive" type="object" string="Deactivate" invisible="state == 'inactive'" groups="t4_coreapi.group_core_api_manager"/>
                    <button name="action_view_credentials" type="object" string="View Credentials" invisible="not id" groups="t4_coreapi.group_core_api_manager"/>
                    <button name="action_regenerate_secret" type="object" string="Regenerate Secret" invisible="not id" groups="t4_coreapi.group_core_api_manager"/>
                    <button name="action_revoke_token" type="object" string="Revoke All Active Tokens" class="btn-warning" invisible="not has_active_token" groups="t4_coreapi.group_core_api_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="active,inactive" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Inactive" bg_color="text-bg-danger" invisible="state == 'active'"/>
                    <widget name="web_ribbon" title="Suspicious Traffic" bg_color="text-bg-warning" invisible="traffic_status != 'suspicious'"/>
                    <div class="alert alert-info" role="alert" invisible="id">
                        Client ID and Client Secret are generated automatically when you save.
                        Authorized Core API managers can view them again from View Credentials.
                    </div>
                    <div class="alert alert-warning mb-3" role="alert" invisible="traffic_status != 'suspicious'">
                        Request rate exceeded the configured limit. Excess requests are rejected. Review active tokens and revoke a suspicious token, or revoke all tokens when the shared Application credential is compromised.
                    </div>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_tokens" type="object" class="oe_stat_button" icon="fa-key" invisible="not id">
                            <field name="token_count" widget="statinfo" string="Tokens"/>
                        </button>
                        <button name="action_view_logs" type="object" class="oe_stat_button" icon="fa-list" invisible="not id">
                            <field name="log_count" widget="statinfo" string="Logs"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                                        <field name="domain_id" options="{'no_create': True}"/>
                            <field name="client_id" readonly="1" invisible="not client_id"/>
                            <field name="token_ttl_hours"/>
                            <field name="refresh_token_ttl_days"/>
                        </group>
                        <group string="Application Status">
                            <field name="traffic_status" widget="badge" decoration-success="traffic_status == 'normal'" decoration-warning="traffic_status == 'elevated'" decoration-danger="traffic_status == 'suspicious'"/>
                            <field name="api_requests_per_minute" readonly="1"/>
                            <field name="rate_limit_per_minute" readonly="1"/>
                            <field name="auth_requests_per_minute" readonly="1" string="Auth Requests (last min)"/>
                            <field name="has_active_token" invisible="1"/>
                            <field name="credentials_pending" invisible="1"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="API Routes" name="gateway_routes">
                            <field name="endpoint_ids" nolabel="1" context="{'default_application_id': id}">
                                <list editable="bottom">
                                    <field name="application_id" column_invisible="1"/>
                                    <field name="version_id" options="{'no_create': True}"/>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="route_suffix"/>
                                    <field name="route_pattern" column_invisible="1"/>
                                    <field name="http_methods"/>
                                    <field name="action_id" options="{'no_create': True, 'no_quick_create': True, 'no_create_edit': True}"/>
                                    <field name="route_active"/>
                                </list>
                            </field>
                        </page>

                        <page string="Authentication Guide" name="auth_guide" invisible="not client_id">
                            <div class="alert alert-info mb-3" role="alert">
                                <strong>How to authenticate</strong>
                                <ol class="mb-0 mt-2">
                                    <li>Use your Odoo <strong>database name</strong> (shown below) via <code>?db=...</code>. This is not the module name.</li>
                                    <li>Send <strong>Client ID</strong> and <strong>Client Secret</strong> once to receive an access/refresh token pair.</li>
                                    <li>Multiple clients may use the same credentials; each authentication returns an independent token pair.</li>
                                    <li>Call a Gateway Route with <code>Authorization: Bearer &lt;access_token&gt;</code>.</li>
                                    <li>The token is accepted only when the requested Route Path belongs to this Application.</li>
                                    <li>Before the access token expires, call <code>/auth/refresh</code> with the current refresh token. Refresh rotates automatically; no credential re-authentication is required during continuous operation.</li>
                                </ol>
                            </div>
                            <group>
                                <group string="Step 1: Get access token">
                                    <field name="api_database_name" readonly="1" widget="CopyClipboardChar"/>
                                    <field name="api_base_url" readonly="1"/>
                                    <field name="auth_endpoint_url" readonly="1" widget="CopyClipboardChar"/>
                                    <label for="auth_curl_example" string="Example request"/>
                                    <div class="o_row">
                                        <field name="auth_curl_example" readonly="1" nolabel="1" colspan="2" class="font-monospace text-muted"/>
                                    </div>
                                </group>
                                <group string="Step 2: Call a Gateway Route">
                                    <div colspan="2" class="text-muted">
                                        Replace <code>&lt;access_token&gt;</code> with the token from step 1.
                                        Example URL pattern: <code>/{version}/{route_path}</code>
                                    </div>
                                    <label for="api_call_curl_example" string="Example request"/>
                                    <div class="o_row">
                                        <field name="api_call_curl_example" readonly="1" nolabel="1" colspan="2" class="font-monospace text-muted"/>
                                    </div>
                                </group>
                            </group>
                            <group string="Token response (success)">
                                <div colspan="2" class="font-monospace text-muted">
                                    {<br/>
                                      "status": "success",<br/>
                                      "message": "OK",<br/>
                                      "data": {<br/>
                                        "access_token": "…",<br/>
                                        "refresh_token": "…",<br/>
                                        "token_type": "Bearer",<br/>
                                        "expires_in": 86400,<br/>
                                        "refresh_expires_in": 2592000<br/>
                                      }<br/>
                                    }
                                </div>
                            </group>
                            <group string="Auth error examples">
                                <div colspan="2" class="font-monospace text-muted">
                                    {"status": "error", "message": "client_id is required."}<br/>
                                    {"status": "error", "message": "client_secret is required."}<br/>
                                    {"status": "error", "message": "No application found for the given client_id."}<br/>
                                    {"status": "error", "message": "Invalid client_secret for the given client_id."}<br/>
                                    {"status": "error", "message": "Application \"My App\" is inactive."}
                                </div>
                            </group>
                        </page>

                        <page string="Security" name="security">
                            <group>
                                <group string="Rate Limits">
                                    <field name="rate_limit_per_minute"/>
                                    <div class="text-muted" colspan="2">
                                        API limits apply independently to each access token. Authentication is throttled per source IP.
                                    </div>
                                </group>
                                <group>
                                    <field name="allowed_ips" placeholder="203.0.113.10&#10;198.51.100.0/24"/>
                                </group>
                            </group>
                        </page>
                    </notebook>

                    <group>
                        <field name="notes" placeholder="Internal notes…" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
                <!-- <chatter/> -->
            </form>
        </field>
    </record>

    <record id="action_core_api_application" model="ir.actions.act_window">
        <field name="name">Applications</field>
        <field name="res_model">core.api.application</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_active': 1}</field>
    </record>

</odoo>
