<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_core_api_application_secret_wizard_form" model="ir.ui.view">
        <field name="name">core.api.application.secret.wizard.form</field>
        <field name="model">core.api.application.secret.wizard</field>
        <field name="arch" type="xml">
            <form string="Application Credentials">
                <sheet>
                    <div class="alert alert-warning mb-4" role="alert">
                        <strong>Copy these credentials now.</strong>
                        The client secret is shown only once and cannot be retrieved later.
                    </div>
                    <field name="application_id" invisible="1"/>
                    <group string="Credentials">
                        <field name="client_id"
                               string="Client ID"
                               readonly="1"
                               widget="CopyClipboardChar"/>
                        <field name="client_secret"
                               string="Client Secret"
                               readonly="1"
                               widget="CopyClipboardChar"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm"
                            type="object"
                            string="Done"
                            class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
