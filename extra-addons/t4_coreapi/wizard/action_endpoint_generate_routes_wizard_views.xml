<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_action_endpoint_generate_routes_wizard_form" model="ir.ui.view">
        <field name="name">action.endpoint.generate.routes.wizard.form</field>
        <field name="model">action.endpoint.generate.routes.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate API Actions &amp; Routes">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        This Endpoint Manager is an API endpoint set. Select one or more Applications that should receive the generated Gateway Routes.
                    </div>
                    <group>
                        <field name="endpoint_manager_id" readonly="1"/>
                        <field name="version_id" options="{'no_create': True}"/>
                        <field name="application_ids" widget="many2many_tags" options="{'no_create': True}"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_generate" type="object" string="Generate" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
