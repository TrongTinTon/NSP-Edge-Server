<odoo>
    <record id="view_nsp_vehicle_card_search" model="ir.ui.view">
        <field name="name">nsp.vehicle.card.search</field>
        <field name="model">nsp.vehicle.card</field>
        <field name="arch" type="xml">
            <search>
                <field name="vehicle_id"/>
                <field name="card_id"/>
                <field name="tid"/>
                <filter string="Active" name="active_cards" domain="[('state','=','active')]"/>
                <filter string="Revoked" name="revoked_cards" domain="[('state','=','revoked')]"/>
                <separator/>
                    <filter string="Vehicle" name="group_vehicle" context="{'group_by':'vehicle_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                </search>
        </field>
    </record>

    <record id="view_nsp_vehicle_card_list" model="ir.ui.view">
        <field name="name">nsp.vehicle.card.list</field>
        <field name="model">nsp.vehicle.card</field>
        <field name="arch" type="xml">
            <list string="Vehicle Cards">
                <field name="vehicle_id"/>
                <field name="tid"/>
                <field name="card_id"/>
                <field name="state" widget="badge" class="nsp-card-status-badge" decoration-success="state == 'active'" decoration-muted="state == 'revoked'"/>
                <field name="assigned_at" optional="hide"/>
                <field name="revoked_at" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_vehicle_card_form" model="ir.ui.view">
        <field name="name">nsp.vehicle.card.form</field>
        <field name="model">nsp.vehicle.card</field>
        <field name="arch" type="xml">
            <form string="Vehicle Card">
                <header>
                    <button name="action_activate" string="Set Active" type="object" invisible="state == 'active'" class="btn-primary"/>
                    <button name="action_revoke" string="Revoke" type="object" invisible="state == 'revoked'"/>
                    <field name="state" widget="statusbar" statusbar_visible="active,revoked"/>
                </header>
                <sheet>
                    <group>
                        <field name="vehicle_id"/>
                        <field name="card_id" domain="[('card_type','=','vehicle_card'), ('usage_state','=','available')]" options="{'no_create': True}"/>
                        <field name="tid" readonly="1"/>
                        <field name="assigned_at"/>
                        <field name="revoked_at" readonly="1"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nsp_vehicle_card" model="ir.actions.act_window">
        <field name="name">Vehicle Cards</field>
        <field name="res_model">nsp.vehicle.card</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_nsp_vehicle_card_search"/>
        <field name="context">{'search_default_active_cards': 1}</field>
    </record>
</odoo>
