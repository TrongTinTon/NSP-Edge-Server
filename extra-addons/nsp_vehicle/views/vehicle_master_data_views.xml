<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nsp_vehicle_type_list" model="ir.ui.view">
        <field name="name">nsp.vehicle.type.list</field>
        <field name="model">nsp.vehicle.type</field>
        <field name="arch" type="xml">
            <list string="Vehicle Types">
                <field name="name"/>
                <field name="code" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_vehicle_type_form" model="ir.ui.view">
        <field name="name">nsp.vehicle.type.form</field>
        <field name="model">nsp.vehicle.type</field>
        <field name="arch" type="xml">
            <form string="Vehicle Type">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nsp_vehicle_type" model="ir.actions.act_window">
        <field name="name">Vehicle Types</field>
        <field name="res_model">nsp.vehicle.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_nsp_vehicle_brand_list" model="ir.ui.view">
        <field name="name">nsp.vehicle.brand.list</field>
        <field name="model">nsp.vehicle.brand</field>
        <field name="arch" type="xml">
            <list string="Brands">
                <field name="name"/>
                <field name="code" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_vehicle_brand_form" model="ir.ui.view">
        <field name="name">nsp.vehicle.brand.form</field>
        <field name="model">nsp.vehicle.brand</field>
        <field name="arch" type="xml">
            <form string="Brand">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nsp_vehicle_brand" model="ir.actions.act_window">
        <field name="name">Brands</field>
        <field name="res_model">nsp.vehicle.brand</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_nsp_vehicle_model_list" model="ir.ui.view">
        <field name="name">nsp.vehicle.model.list</field>
        <field name="model">nsp.vehicle.model</field>
        <field name="arch" type="xml">
            <list string="Models">
                <field name="name"/>
                <field name="brand_id"/>
                <field name="code" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_vehicle_model_form" model="ir.ui.view">
        <field name="name">nsp.vehicle.model.form</field>
        <field name="model">nsp.vehicle.model</field>
        <field name="arch" type="xml">
            <form string="Model">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="brand_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nsp_vehicle_model" model="ir.actions.act_window">
        <field name="name">Models</field>
        <field name="res_model">nsp.vehicle.model</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_nsp_vehicle_color_list" model="ir.ui.view">
        <field name="name">nsp.vehicle.color.list</field>
        <field name="model">nsp.vehicle.color</field>
        <field name="arch" type="xml">
            <list string="Colors">
                <field name="name"/>
                <field name="code" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_nsp_vehicle_color_form" model="ir.ui.view">
        <field name="name">nsp.vehicle.color.form</field>
        <field name="model">nsp.vehicle.color</field>
        <field name="arch" type="xml">
            <form string="Color">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nsp_vehicle_color" model="ir.actions.act_window">
        <field name="name">Colors</field>
        <field name="res_model">nsp.vehicle.color</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
